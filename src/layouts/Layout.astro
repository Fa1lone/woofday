---
interface Props {
  title?: string;
  description?: string;
  schema?: object | object[];
  noindex?: boolean;
  canonical?: string;
}
const {
  title = 'Woof Day 2026 — Fête canine gratuite à Ambérac, Charente (13 sept.)',
  description = 'La grande fête canine de Charente : 13 septembre 2026 à Ambérac. Entrée gratuite, 50+ exposants, animations, tombola. Au profit du Refuge de l\'Angoumois.',
  schema,
  noindex = false,
  canonical = Astro.url.href.split('?')[0],
} = Astro.props;

const OG_IMAGE = 'https://www.woofday.fr/images/og-woofday.jpg';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <link rel="icon" type="image/svg+xml" href="/logos/tete-chien.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Kalam:wght@400;700&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
    )}
  </head>
  <body>
    <div id="toast"></div>
    <slot />
    <script>
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in') }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => obs.observe(el));

      (window as any).showToast = (msg: string, duration = 3200) => {
        const t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), duration);
      };
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  html,
  body {
    overflow-x: hidden;
  }

  .dog-deco {
    position: absolute;
    bottom: 0;
    width: fit-content;
    pointer-events: none;
    line-height: 0;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .dog-deco {
      display: none;
      opacity: 0;
      pointer-events: none;
    }
  }
</style>
