---
import Layout from '../layouts/Layout.astro';
import DoodleMark from '../components/DoodleMark.astro';
import LogoTicker from '../components/LogoTicker.astro';

const poles = [
  { icon: '🎓', nom: 'Éducation & Relation',     desc: 'Éducateurs, comportementalistes, agility, obéissance positive.' },
  { icon: '💚', nom: 'Santé & Bien-être',         desc: 'Vétérinaires, ostéopathes, physiothérapie, relaxation, spa.' },
  { icon: '🥣', nom: 'Nutrition & Alimentation',  desc: 'Alimentation naturelle, croquettes artisanales, friandises, barf.' },
  { icon: '🏃', nom: 'Activités & Fun',           desc: 'Sport canin, aquatique, randonnée, jeux, photography.' },
  { icon: '🧶', nom: 'Artisanat & Accessoires',   desc: 'Créateurs de colliers, laisses, vêtements, bijoux, artisanat.' },
  { icon: '❤️', nom: 'Associations & Solidarité', desc: 'Refuges, associations, bénévolat, adoption, protection animale.' },
];
---

<Layout title="Devenir Exposant — Woof Day 2026" description="Rejoignez le Woof Day comme exposant le 13 septembre 2026 à Ambérac. Réservez votre stand pour l'édition 2.">

<!-- NAV -->
<nav style="
  position:fixed;top:16px;left:50%;translate:-50% 0;z-index:100;
  width:min(calc(100% - 32px),1100px);
  background:rgba(243,241,199,.92);backdrop-filter:blur(12px);
  border:1.5px solid var(--creme-dark);border-radius:var(--r-pill);
  padding:10px 20px;display:flex;align-items:center;justify-content:space-between;
">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <img src="/logos/tete-chien.svg" alt="" style="height:32px" />
    <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
  </a>
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:nowrap">
    <a href="/" class="nav-links" style="font-family:var(--f-body);font-size:12px;font-weight:600;color:var(--truffe);opacity:.7;text-decoration:none;white-space:nowrap">← Accueil</a>
    <div class="nav-links" style="display:flex;align-items:center;gap:12px;margin:0 4px;flex-wrap:nowrap">
      {[
        ['/#pourquoi','LE WOOF DAY'],
        ['/#zones','PROGRAMME'],
        ['/#exposants','LE VILLAGE'],
        ['/#infos','INFOS PRATIQUES'],
        ['/#faq','FAQ']
      ].map(([h,l]) => (
        <a href={h} style="font-family:var(--f-body);font-size:10px;font-weight:700;color:var(--truffe);text-decoration:none;opacity:.6;letter-spacing:0.05em;white-space:nowrap" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.6'">{l}</a>
      ))}
    </div>
    <a href="/sponsor" class="nav-links" style="font-family:var(--f-body);font-size:12px;font-weight:700;color:var(--vert);text-decoration:none;background:rgba(38,66,43,.1);border:1.5px solid rgba(38,66,43,.3);border-radius:var(--r-pill);padding:6px 12px;white-space:nowrap">Devenir sponsor 🤝</a>
    <a href="#form-exposant" class="btn btn-terre" style="font-size:13px;padding:8px 18px;white-space:nowrap">Je suis intéressé 🐾</a>
  </div>
</nav>

<!-- HERO -->
<section style="
  min-height:80svh;padding:120px clamp(20px,5vw,40px) clamp(120px,20vw,200px);
  background:var(--terre);color:#fff;text-align:center;
  position:relative;overflow:hidden;
">
  <!-- Grandes pattes fond — style POSTINSTA01 (truffe sur terre) -->
  <div class="paw-mark" style="left:-6%;top:-8%;transform:rotate(-15deg)">🐾</div>
  <div class="paw-mark" style="right:-4%;top:5%;transform:rotate(20deg)">🐾</div>
  <div class="paw-mark" style="left:38%;bottom:-12%;transform:rotate(-5deg);font-size:clamp(120px,18vw,260px);opacity:.09">🐾</div>

  <!-- Contenu centré -->
  <div style="position:relative;z-index:3;max-width:700px;margin:0 auto">
    <div data-reveal style="margin-bottom:20px">
      <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:var(--r-pill);padding:6px 16px;font-family:var(--f-body);font-size:12px;font-weight:600">Édition 2 · 13 sept. 2026</span>
    </div>
    <!-- Brushstroke heading — POSTINSTA01 exact (coup de pinceau gris-bleu, texte terre) -->
    <div data-reveal data-delay="1" style="margin-bottom:24px;display:inline-block;position:relative;transform:rotate(-1.2deg)">
      <!-- SVG brushstroke organique en fond — s'étire en preserveAspectRatio none -->
      <svg style="position:absolute;inset:-6px -4px;width:calc(100% + 8px);height:calc(100% + 12px);z-index:0;filter:drop-shadow(5px 6px 0px rgba(0,0,0,.22))"
           viewBox="0 0 320 124" preserveAspectRatio="none" aria-hidden="true">
        <path d="M16,20 C8,10 10,3 22,2 L298,1 C310,0 317,6 316,18 C318,36 315,60 317,79 C319,97 313,110 300,112 L20,115 C7,116 1,109 2,97 C1,79 4,54 3,38 Z" fill="#9fc0cb"/>
      </svg>
      <h1 style="position:relative;z-index:1;font-family:var(--f-head);font-size:clamp(36px,7vw,72px);font-weight:700;line-height:1.1;color:var(--terre);text-align:center;padding:20px 44px;display:inline-block">
        DEVENIR<br/>EXPOSANT !
      </h1>
    </div>
    <p data-reveal data-delay="2" style="font-family:var(--f-body);font-size:clamp(16px,2.5vw,20px);opacity:.85;max-width:50ch;margin:0 auto 28px;line-height:1.65">
      Réservez votre stand au Woof Day et rencontrez des centaines d'amoureux des chiens en Charente.
    </p>
    <!-- Stat pills -->
    <div data-reveal data-delay="3" style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:32px">
      {['✅ Éd.1 : 800 visiteurs','🚀 Éd.2 : 1200+ visés','⏱️ Réponse sous 72h','⚠️ Places limitées par pôle'].map(t => (
        <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:var(--r-pill);padding:7px 14px;font-family:var(--f-body);font-size:12px;font-weight:600">{t}</span>
      ))}
    </div>
    <div data-reveal data-delay="4" style="position:relative;display:inline-flex;isolation:isolate;margin-top:24px">
      <DoodleMark variant="circle" color="rgba(255,255,255,.5)" style="left:50%;top:50%;width:calc(100% + 78px);height:auto;translate:-50% -50%;transform:rotate(-2deg)" />
      <DoodleMark variant="burst" color="rgba(255,255,255,.55)" style="right:-34px;top:-50px;width:72px;height:auto;transform:rotate(16deg)" />
      <a href="#form-exposant" class="btn" style="position:relative;background:rgba(255,255,255,.95);color:var(--terre);font-size:clamp(16px,2.5vw,20px);padding:18px 42px;box-shadow:0 8px 32px rgba(0,0,0,.25)">
        Candidater maintenant 🏪
      </a>
    </div>
  </div>

  <!-- Border collie face terre — fond orange, centré bas -->
  <div class="dog-deco" style="position:absolute;bottom:clamp(-230px,-18vw,-150px);right:clamp(-170px,-8vw,-70px);width:fit-content;pointer-events:none;line-height:0;z-index:1">
    <img src="/images/dog-border-collie-sit-orange.png" alt="" aria-hidden="true"
      style="width:clamp(230px,29vw,410px);display:block;filter:drop-shadow(0 -12px 40px rgba(0,0,0,.3));" />
  </div>

  <!-- Annotation bubble gauche "Réserver votre stand" -->
  <div style="position:absolute;bottom:clamp(80px,18vw,180px);left:clamp(20px,7%,80px);z-index:4;pointer-events:none">
    <div style="font-family:var(--f-hand);font-size:clamp(14px,2vw,18px);color:rgba(255,255,255,.85);border:2.5px solid rgba(255,255,255,.45);border-radius:50%;padding:14px 22px;transform:rotate(-6deg);text-align:center;line-height:1.4;display:inline-block;position:relative">
      Réserver votre stand<br/>pour l'édition 2 !
      <DoodleMark variant="arrow" color="white" style="position:absolute;bottom:-40px;right:-10px;width:44px;height:auto;transform:rotate(10deg);opacity:.55" />
    </div>
  </div>

  <!-- Slant bottom -->
  <div style="position:absolute;bottom:-1px;left:0;right:0;height:60px;background:var(--bg);clip-path:polygon(0 100%,100% 0,100% 100%)"></div>
</section>

<LogoTicker />

<!-- GALERIE ÉD.1 — preuve sociale -->
<section id="edition-2" class="sec" style="background:var(--bg)">
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-terre">Édition précédente</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px);color:var(--truffe)">La preuve que ça marche</h2>
    </div>
    <!-- Stats -->
    <div data-reveal style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:32px">
      {[
        { val: '800', label: 'visiteurs Éd.1', bg: 'var(--truffe)', color: '#fff' },
        { val: '1200+', label: 'objectif Éd.2', bg: 'var(--terre)', color: '#fff' },
        { val: '30+', label: 'exposants pionniers', bg: 'var(--vert)', color: '#fff' },
      ].map(s => (
        <div style={`background:${s.bg};color:${s.color};border-radius:var(--r-lg);padding:28px;text-align:center`}>
          <div style="font-family:var(--f-head);font-size:clamp(36px,5vw,54px);font-weight:700;line-height:1">{s.val}</div>
          <div style="font-family:var(--f-body);font-size:13px;opacity:.75;margin-top:6px;text-transform:uppercase;letter-spacing:.08em;font-weight:600">{s.label}</div>
        </div>
      ))}
    </div>
    <!-- Photos ambiance -->
    <div style="display:grid;grid-template-columns:2fr 1fr;grid-template-rows:auto auto;gap:12px">
      <div style="grid-row:1/3;border-radius:var(--r-xl);overflow:hidden;min-height:280px">
        <img src="/images/woofday-ambiance-01.webp" alt="Ambiance Woof Day" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
      </div>
      <div style="border-radius:var(--r-lg);overflow:hidden;min-height:130px">
        <img src="/images/woofday-ambiance-02.webp" alt="Chien au Woof Day" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
      </div>
      <div style="border-radius:var(--r-lg);overflow:hidden;min-height:130px">
        <img src="/images/woofday-ambiance-04.webp" alt="Stand exposant" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- POURQUOI EXPOSER -->
<section id="pourquoi-exposer" class="sec" style="background:var(--creme);position:relative;overflow:hidden">
  <!-- Visuels déco — pattes + chien peeking -->
  <div class="paw-mark-bold" style="right:-5%;bottom:-8%;transform:rotate(18deg)">🐾</div>
  <div class="paw-mark-bold" style="left:-3%;top:10%;transform:rotate(-22deg);opacity:.16">🐾</div>
  <img src="/images/dog-terrier-face-truffe.png" alt="" aria-hidden="true" style="position:absolute;bottom:-60px;right:-40px;width:clamp(160px,22vw,300px);opacity:.18;pointer-events:none;filter:drop-shadow(0 0 0 transparent);transform:scaleX(-1)" />
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-truffe">Pourquoi venir</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px);color:var(--truffe)">Ce que vous gagnez</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px">
      {[
        { icon: '👥', titre: 'Une audience qualifiée', desc: 'Des centaines de visiteurs passionnés par les chiens et le bien-être animal. Votre cœur de cible.', bg: 'var(--truffe)', color: '#fff' },
        { icon: '📍', titre: 'Un emplacement premium', desc: 'Stand bien situé dans les zones thématiques. Plan de village pensé pour le flux visiteurs.', bg: 'var(--creme-dark)', color: 'var(--truffe)' },
        { icon: '📸', titre: 'Kit media offert', desc: 'Visuels Story, Post, Affiche PDF et Bannière email fournis gratuitement pour préparer votre communication.', bg: 'var(--terre)', color: '#fff' },
        { icon: '❤️', titre: 'Une cause commune', desc: 'L\'événement reverse 100% des bénéfices nets au Refuge. Un argument fort auprès de votre audience.', bg: 'var(--vert)', color: '#fff' },
      ].map((a, i) => (
        <div data-reveal data-delay={String(i + 1)} style={`background:${a.bg};color:${a.color};border-radius:var(--r-xl);padding:28px;position:relative;overflow:hidden`}>
          <div style={`font-family:var(--f-head);font-size:72px;font-weight:700;opacity:.1;position:absolute;top:-8px;right:12px;line-height:1;pointer-events:none`}>{String(i+1).padStart(2,'0')}</div>
          <div style="font-size:36px;margin-bottom:12px;position:relative;z-index:1">{a.icon}</div>
          <h3 style="font-family:var(--f-head);font-size:20px;font-weight:700;margin-bottom:8px;position:relative;z-index:1">{a.titre}</h3>
          <p style={`font-family:var(--f-body);font-size:14px;line-height:1.7;opacity:.85;position:relative;z-index:1`}>{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- NOUVEAUTÉS 2026 -->
<section class="sec" style="background:var(--vert);color:#fff;position:relative;overflow:hidden">
  <div class="paw-mark" style="left:-4%;bottom:-5%;transform:rotate(-10deg)">🐾</div>
  <div class="paw-mark" style="right:-3%;top:-8%;transform:rotate(25deg)">🐾</div>
  <!-- Golden peeking depuis la gauche -->
  <img src="/images/dog-golden-vert.png" alt="" aria-hidden="true" style="position:absolute;left:-80px;bottom:-30px;width:clamp(200px,26vw,360px);opacity:.22;pointer-events:none;transform:scaleX(-1)" />
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-white">Nouveautés</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px)">Ce qui change pour l'Éd.2</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px">
      {[
        { icon: '⚙️', titre: 'Organisation Fluide', desc: 'Plan de village revu. Installation simplifiée. Référent dédié à chaque exposant.' },
        { icon: '🗺️', titre: 'Village Lisible', desc: 'Signalétique repensée. Les visiteurs trouvent facilement votre stand.' },
        { icon: '💧', titre: 'Zone Fraîcheur', desc: 'Point eau pour les chiens à chaque zone. Accès eau potable garantit.' },
        { icon: '🎯', titre: 'Jeux & Concours', desc: 'Programme d\'animations renforcé pour amener du passage sur tous les stands.' },
      ].map((n, i) => (
        <div data-reveal data-delay={String(i + 1)} style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:var(--r-lg);padding:24px">
          <div style="font-size:32px;margin-bottom:12px">{n.icon}</div>
          <h3 style="font-family:var(--f-head);font-size:18px;font-weight:700;margin-bottom:8px">{n.titre}</h3>
          <p style="font-family:var(--f-body);font-size:13px;opacity:.8;line-height:1.65">{n.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LE HACK VISIBILITÉ -->
<section class="sec" style="background:var(--bg)">
  <div class="inner">
    <div data-reveal style="background:var(--terre);color:#fff;border-radius:var(--r-xl);padding:clamp(28px,5vw,48px);position:relative;overflow:hidden">
      <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="position:absolute;right:-5%;bottom:-15%;width:35%;opacity:.08;filter:brightness(0) invert(1);pointer-events:none"/>
      <div style="position:relative;z-index:1;max-width:680px">
        <span style="background:rgba(255,255,255,.2);border-radius:var(--r-pill);padding:6px 14px;font-family:var(--f-body);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;margin-bottom:20px;display:inline-block">
          💡 Le hack visibilité
        </span>
        <h2 style="font-family:var(--f-head);font-size:clamp(28px,4vw,44px);font-weight:700;margin-bottom:16px;line-height:1.1">Gagnez des abonnés<br/><em>avant</em> le jour J</h2>
        <p style="font-family:var(--f-body);font-size:15px;line-height:1.8;opacity:.9;margin-bottom:24px">
          Les exposants qui proposent un <strong>lot pour la tombola</strong> ou un <strong>jeu concours Instagram</strong> voient leur audience gonfler avant même l'événement. Les visiteurs viennent <em>spécialement</em> sur votre stand récupérer leur gain.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          {[
            { icon: '🎁', titre: 'Lot tombola', desc: 'Le gagnant VIENT sur votre stand récupérer son lot le jour J.' },
            { icon: '📱', titre: 'Jeu concours', desc: 'Partagez sur Instagram avant l\'événement, récoltez des abonnés qualifiés.' },
          ].map(h => (
            <div style="background:rgba(255,255,255,.12);border-radius:var(--r-lg);padding:20px">
              <div style="font-size:28px;margin-bottom:8px">{h.icon}</div>
              <h3 style="font-family:var(--f-head);font-size:17px;font-weight:700;margin-bottom:6px">{h.titre}</h3>
              <p style="font-family:var(--f-body);font-size:13px;opacity:.85;line-height:1.6">{h.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AVANTAGES -->
<section id="concept" class="sec" style="background:var(--creme);position:relative;overflow:hidden">
  <div class="paw-mark-bold" style="left:-2%;top:5%;transform:rotate(-18deg)">🐾</div>
  <div class="paw-mark-bold" style="right:-4%;bottom:0%;transform:rotate(12deg);opacity:.2">🐾</div>
  <!-- Dachshund face peeking top right -->
  <img src="/images/dog-dachshund-face-bleu.png" alt="" aria-hidden="true" style="position:absolute;top:-20px;right:-30px;width:clamp(130px,18vw,220px);opacity:.2;pointer-events:none;transform:rotate(-8deg)" />
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-vert">Organisation</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px);color:var(--truffe)">6 pôles thématiques</h2>
      <p data-reveal data-delay="2" style="font-family:var(--f-body);font-size:15px;color:var(--truffe);opacity:.7;margin-top:10px;max-width:52ch;margin-left:auto;margin-right:auto">Le village est organisé en pôles. Vous êtes regroupés avec des exposants complémentaires, jamais en concurrence directe.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:12px">
      {poles.map((p, i) => (
        <div data-reveal data-delay={String((i % 3) + 1)} style="background:#fff;border-radius:var(--r-lg);padding:24px;border:1.5px solid var(--creme-dark)">
          <div style="font-size:32px;margin-bottom:10px">{p.icon}</div>
          <h3 style="font-family:var(--f-head);font-size:18px;font-weight:700;color:var(--truffe);margin-bottom:6px">{p.nom}</h3>
          <p style="font-family:var(--f-body);font-size:13px;line-height:1.65;color:var(--truffe);opacity:.7">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LOGISTIQUE -->
<section id="logistique" class="sec" style="background:var(--bg);position:relative;overflow:hidden">
  <div class="paw-mark" style="right:-3%;top:0%;transform:rotate(20deg);opacity:.08">🐾</div>
  <!-- Vizsla peeking bottom left -->
  <img src="/images/dog-vizsla-debout-bleu.png" alt="" aria-hidden="true" style="position:absolute;bottom:-40px;left:-50px;width:clamp(140px,18vw,240px);opacity:.12;pointer-events:none" />
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-terre">Organisation</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px);color:var(--truffe)">Logistique & pratique</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px">
      <!-- Horaires -->
      <div data-reveal style="background:var(--truffe);color:#fff;border-radius:var(--r-xl);padding:28px">
        <h3 style="font-family:var(--f-head);font-size:20px;font-weight:700;margin-bottom:16px">⏰ Horaires</h3>
        {[
          ['Veille (12 sept.)', '16h – 19h', 'Installation possible'],
          ['Jour J (13 sept.)', '7h – 9h', 'Tout doit être prêt à 9h'],
          ['Ouverture public', '10h – 18h', '—'],
          ['Démontage', 'Dès 18h', 'Retrait le même jour'],
        ].map(([jour, heure, note]) => (
          <div style="display:flex;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.1);align-items:baseline">
            <div style="flex:1;font-family:var(--f-body);font-size:13px;opacity:.75">{jour}</div>
            <div style="font-family:var(--f-head);font-size:16px;font-weight:700">{heure}</div>
          </div>
        ))}
      </div>
      <!-- Formats stands -->
      <div data-reveal data-delay="2" style="background:var(--creme);border-radius:var(--r-xl);padding:28px">
        <h3 style="font-family:var(--f-head);font-size:20px;font-weight:700;color:var(--truffe);margin-bottom:16px">📐 Formats de stand</h3>
        {[
          ['Petit', '3 m²', 'Artisanat, asso, créateurs'],
          ['Standard', '6 m²', 'Professionnels, services'],
          ['Grand', '9 m²+', 'Marques, démonstrations'],
        ].map(([nom, surface, cible]) => (
