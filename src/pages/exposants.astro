<script>
  // Charte toggle
  document.getElementById('toggle-charte')?.addEventListener('click', function() {
    const content = document.getElementById('charte-content');
    const open = content.style.display !== 'none';
    content.style.display = open ? 'none' : 'block';
    this.textContent = open ? 'Voir ce qui est interdit ▾' : 'Masquer ▴';
  });

  // Taille stand cards
  document.querySelectorAll('.taille-radio').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.taille-card').forEach(card => {
        card.style.borderColor = 'var(--creme-dark)';
        card.style.background = '';
      });
      if (radio.checked) {
        const card = radio.closest('label').querySelector('.taille-card');
        card.style.borderColor = 'var(--terre)';
        card.style.background = '#fff5f0';
      }
    });
  });

  // Stepper
  let currentStep = 1;
  const totalSteps = 4;

  window.stepNav = (dir) => {
    const newStep = currentStep + dir;
    if (newStep < 1 || newStep > totalSteps) return;
    // validate current step fields before going forward
    if (dir > 0) {
      const panel = document.getElementById(`step-${currentStep}`);
      const required = panel.querySelectorAll('[required]');
      let valid = true;
      required.forEach(el => {
        if (!el.value.trim()) {
          el.style.borderColor = '#c0392b';
          valid = false;
          setTimeout(() => el.style.borderColor = '', 2000);
        }
      });
      if (!valid) return;
    }
    document.getElementById(`step-${currentStep}`).style.display = 'none';
    document.getElementById(`step-${newStep}`).style.display = 'block';
    for (let i = 1; i <= totalSteps; i++) {
      const dot = document.getElementById(`dot-${i}`);
      if (dot) dot.classList.toggle('active', i <= newStep);
    }
    currentStep = newStep;
    const backBtn = document.getElementById('btn-back');
    const nextBtn = document.getElementById('btn-next');
    const submitBtn = document.getElementById('btn-submit');
    backBtn.style.display = currentStep > 1 ? 'inline-flex' : 'none';
    nextBtn.style.display = currentStep < totalSteps ? 'inline-flex' : 'none';
    submitBtn.style.display = currentStep === totalSteps ? 'inline-flex' : 'none';
    window.scrollTo({ top: document.getElementById('form-exposant').offsetTop - 80, behavior: 'smooth' });
  };

  // FAQ toggle
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const open = content.style.display !== 'none';
      document.querySelectorAll('.faq-content').forEach(c => c.style.display = 'none');
      document.querySelectorAll('.faq-btn span:last-child').forEach(s => s.textContent = '+');
      if (!open) {
        content.style.display = 'block';
        btn.querySelector('span:last-child').textContent = '−';
      }
    });
  });

  // Form submit
  document.getElementById('exposant-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('btn-submit');
    submitBtn.textContent = 'Envoi…'; submitBtn.disabled = true;
    try {
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/api/exposant', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) {
        e.target.style.display = 'none';
        document.getElementById('form-success').style.display = 'block';
        window.showToast?.('✅ Candidature envoyée !');
      } else throw new Error();
    } catch {
      submitBtn.textContent = '❌ Erreur — Réessayez';
      submitBtn.disabled = false;
    }
  });
</script>
