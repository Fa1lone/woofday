---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const tagColors: Record<string, string> = {
  origines: 'var(--vert)',
  pratique: 'var(--terre)',
  Cynofeel: 'var(--truffe)',
};
---
<Layout
  title="Blog — Woof Day"
  description="Actualités, conseils et coulisses du Woof Day, la grande fête canine de Charente organisée par Méline (Cynofeel)."
>
  <nav id="nav" style="
    position:fixed;top:16px;left:50%;translate:-50% 0;
    z-index:100;width:min(calc(100% - 32px),1100px);
    background:rgba(243,241,199,.92);backdrop-filter:blur(12px);
    border:1.5px solid var(--creme-dark);border-radius:var(--r-pill);
    padding:10px 20px;display:flex;align-items:center;justify-content:space-between;
  ">
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
      <img src="/logos/tete-chien.svg" alt="" style="height:32px;width:32px;object-fit:contain"/>
      <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
    </a>
    <a href="/" style="font-family:var(--f-body);font-size:14px;color:var(--truffe);text-decoration:none;opacity:.7">← Retour à l'accueil</a>
  </nav>

  <!-- HERO BLOG -->
  <section style="
    background:var(--truffe);color:#fff;
    padding:clamp(120px,18vw,180px) clamp(20px,5vw,40px) clamp(64px,10vw,100px);
    text-align:center;position:relative;overflow:hidden;
  ">
    <div style="position:absolute;inset:0;opacity:.05;font-size:180px;display:flex;align-items:center;justify-content:center;pointer-events:none">🐾</div>
    <div style="position:relative;z-index:1;max-width:700px;margin:0 auto">
      <span style="
        font-family:var(--f-hand);font-size:14px;
        background:var(--terre);color:#fff;
        border-radius:var(--r-pill);padding:6px 18px;display:inline-block;margin-bottom:20px;
      ">Le blog du Woof Day</span>
      <h1 style="font-family:var(--f-head);font-size:clamp(42px,7vw,72px);font-weight:700;margin-bottom:20px;line-height:1.05">
        Actus & coulisses
      </h1>
      <p style="font-family:var(--f-body);font-size:18px;line-height:1.7;opacity:.75;max-width:50ch;margin:0 auto">
        L'histoire du Woof Day, des conseils pour votre venue, et les petites histoires derrière la grande fête canine de Charente.
      </p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section style="background:var(--bg);padding:clamp(64px,10vw,100px) clamp(20px,5vw,40px)">
    <div style="max-width:960px;margin:0 auto">
      {posts.length === 0 ? (
        <p style="text-align:center;font-family:var(--f-body);opacity:.5;font-size:16px">Aucun article pour l'instant. Revenez bientôt !</p>
      ) : (
        <div style="display:grid;gap:clamp(20px,3vw,32px)">
          {posts.map((post, i) => (
            <article style="
              background:#fff;border-radius:var(--r-lg);
              border:1.5px solid var(--creme-dark);
              overflow:hidden;
              display:grid;
              grid-template-columns: 280px 1fr;
              transition:box-shadow .25s,transform .25s;
              box-shadow:0 2px 14px rgba(105,50,45,.06);
            "
              onmouseover="this.style.boxShadow='0 10px 36px rgba(105,50,45,.13)';this.style.transform='translateY(-3px)'"
              onmouseout="this.style.boxShadow='0 2px 14px rgba(105,50,45,.06)';this.style.transform=''"
            >
              <!-- Image -->
              <a href={`/blog/${post.id}`} style="display:block;overflow:hidden;aspect-ratio:4/3;background:var(--creme)">
                {post.data.image ? (
                  <img
                    src={`${post.data.image.replace('w=1200','w=560')}`}
                    alt={post.data.title}
                    loading={i < 2 ? 'eager' : 'lazy'}
                    style="width:100%;height:100%;object-fit:cover;transition:transform .4s ease"
                    onmouseover="this.style.transform='scale(1.04)'"
                    onmouseout="this.style.transform='scale(1)'"
                  />
                ) : (
                  <div style="width:100%;height:100%;min-height:200px;display:flex;align-items:center;justify-content:center;font-size:64px;background:var(--creme)">🐾</div>
                )}
              </a>

              <!-- Contenu -->
              <div style="padding:clamp(20px,3vw,32px);display:flex;flex-direction:column;justify-content:space-between;gap:14px">
                <div>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
                    {post.data.tags.slice(0,3).map(tag => (
                      <span style={`
                        font-family:var(--f-body);font-size:10px;font-weight:700;
                        background:${tagColors[tag] ?? 'var(--bleu)'};color:#fff;
                        border-radius:var(--r-pill);padding:3px 10px;
                        text-transform:uppercase;letter-spacing:.07em;
                      `}>{tag}</span>
                    ))}
                  </div>
                  <h2 style="font-family:var(--f-head);font-size:clamp(18px,2.2vw,24px);margin-bottom:10px;line-height:1.2;color:var(--truffe)">
                    <a href={`/blog/${post.id}`} style="text-decoration:none;color:inherit">{post.data.title}</a>
                  </h2>
                  <p style="font-family:var(--f-body);font-size:14px;line-height:1.7;opacity:.65;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">{post.data.description}</p>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
                  <div style="display:flex;align-items:center;gap:9px">
                    <div style="width:28px;height:28px;background:var(--terre);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0">🐾</div>
                    <div>
                      <div style="font-family:var(--f-body);font-size:12px;font-weight:600;color:var(--truffe)">{post.data.author}</div>
                      <div style="font-family:var(--f-body);font-size:11px;opacity:.45">{formatDate(post.data.pubDate)}</div>
                    </div>
                  </div>
                  <a href={`/blog/${post.id}`} style="
                    font-family:var(--f-body);font-size:12px;font-weight:700;
                    color:#fff;text-decoration:none;
                    background:var(--terre);border-radius:var(--r-pill);
                    padding:7px 16px;white-space:nowrap;
                  ">Lire →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <style is:global>
    @media (max-width: 640px) {
      article[style*="grid-template-columns: 280px"] {
        grid-template-columns: 1fr !important;
      }
      article[style*="grid-template-columns: 280px"] a[style*="aspect-ratio"] {
        aspect-ratio: 16/9 !important;
      }
    }
  </style>

  <!-- FOOTER MINI -->
  <footer style="background:var(--truffe);color:#fff;padding:40px clamp(20px,5vw,40px);text-align:center">
    <p style="font-family:var(--f-body);font-size:13px;opacity:.5;margin-bottom:8px">
      © 2026 Woof Day — Fondé par <a href="https://cyno-feel.fr" target="_blank" rel="noopener" style="color:var(--creme);text-decoration:underline;text-underline-offset:3px">Méline · Cynofeel</a>
    </p>
    <a href="/" style="font-family:var(--f-body);font-size:13px;color:var(--creme);opacity:.6;text-decoration:none">← Retour à l'accueil</a>
  </footer>
</Layout>
