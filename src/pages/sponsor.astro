---
import Layout from '../layouts/Layout.astro';
import DoodleMark from '../components/DoodleMark.astro';
import LogoTicker from '../components/LogoTicker.astro';

const packs = [
  {
    id: 'bronze', nom: 'Bronze', prix: '50€', color: '#8B7355', textColor: '#fff',
    avantages: [
      'Remerciements sur les réseaux sociaux',
      'Votre nom mentionné sur le site officiel',
      'Participation au jeu concours Instagram',
    ],
  },
  {
    id: 'argent', nom: 'Argent', prix: '150€', color: '#91acda', textColor: '#26422b',
    avantages: [
      'Logo sur le site officiel (lien actif)',
      'Mention sur place le jour J',
      'Stories Instagram dédiées à votre marque',
      '+ tous les avantages Bronze',
    ],
  },
  {
    id: 'or', nom: 'Or', prix: '300€', color: '#de6c49', textColor: '#fff', highlight: true,
    avantages: [
      'Logo sur affiches & flyers imprimés',
      'Naming d\'un stand bénévole',
      'Post Instagram dédié avant l\'événement',
      '+ tous les avantages Argent',
    ],
  },
  {
    id: 'platine', nom: 'Platine', prix: '600€', color: '#69322d', textColor: '#fff',
    avantages: [
      'Post Instagram dédié + Stories',
      'Kakémono à votre nom sur le site',
      'Naming d\'une zone entière',
      '+ tous les avantages Or',
    ],
  },
  {
    id: 'vip', nom: 'VIP', prix: '1 000€', color: '#26422b', textColor: '#fff', limited: 2,
    avantages: [
      '5 Stories dédiées avant et pendant l\'événement',
      'Logo sur les tenues bénévoles',
      'Roll-up fourni sur le site',
      'Naming d\'une zone + stand',
      '+ tous les avantages Platine',
    ],
  },
  {
    id: 'principal', nom: 'Sponsor Principal', prix: '2 000€', color: '#1a2e1f', textColor: '#fff', limited: 1, star: true,
    avantages: [
      '"Présenté par [votre nom]" sur toutes les communications',
      'Naming de la zone principale',
      '2 posts Instagram dédiés + 8–10 Stories',
      'Logo XXL sur toutes les affiches',
      'Stand VIP offert (9m²)',
      '+ tous les avantages VIP',
    ],
  },
];

const zones = ['🌊 Aquatique','🏆 Agility','🌿 Détente','👶 Famille','🎤 Scène','🌱 Village'];
const stands = ['🎟️ Tombola','☕ Buvette','🧩 Escape Game','🎨 Peinture','📸 Photo','🎭 Spectacle','🏠 Accueil Refuge'];

const goodies = [
  { item: 'Gobelet événementiel', prix: '5€/u' },
  { item: 'Tote bag Woof Day', prix: '20€/u' },
  { item: 'Bandana chien', prix: '8€/u' },
  { item: 'Sac kraft', prix: '6€/u' },
  { item: 'Pochette friandises', prix: '12€/u' },
  { item: 'Jouet logo', prix: '10€/u' },
];
---

<Layout
  title="Devenir sponsor du Woof Day 2026 — Visibilité canine en Charente"
  description="Sponsorisez le Woof Day 2026 à Ambérac : logo sur affiches, site et réseaux. 6 packs dès 50€. Image associée à un événement solidaire et canin en Charente."
  canonical="https://www.woofday.fr/sponsor"
  schema={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Comment fonctionne le sponsoring du Woof Day ?", "acceptedAnswer": { "@type": "Answer", "text": "Vous choisissez un pack (Bronze dès 50€, Argent 150€, Or, Platine…) et votre marque est mise en avant sur le site, les réseaux sociaux, les affiches et le jour de l'événement." } },
      { "@type": "Question", "name": "Le Woof Day reverse-t-il des bénéfices à une cause ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. 100% des bénéfices nets sont reversés au Refuge de l'Angoumois, SPA de Mornac en Charente." } }
    ]
  }}
>

<!-- NAV -->
<nav style="
  position:fixed;top:16px;left:50%;translate:-50% 0;z-index:100;
  width:min(calc(100% - 32px),1100px);
  background:rgba(243,241,199,.92);backdrop-filter:blur(12px);
  border:1.5px solid var(--creme-dark);border-radius:var(--r-pill);
  padding:10px 20px;display:flex;align-items:center;justify-content:space-between;
">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <img src="/logos/tete-chien.svg" alt="" style="height:32px" />
    <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
  </a>
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:nowrap">
    <a href="/" class="nav-links" style="font-family:var(--f-body);font-size:12px;font-weight:600;color:var(--truffe);opacity:.7;text-decoration:none;white-space:nowrap">← Accueil</a>
    <div class="nav-links" style="display:flex;align-items:center;gap:12px;margin:0 4px;flex-wrap:nowrap">
      {[
        ['/#pourquoi','LE WOOF DAY'],
        ['/#zones','PROGRAMME'],
        ['/#exposants','LE VILLAGE'],
        ['/#infos','INFOS PRATIQUES'],
        ['/#faq','FAQ']
      ].map(([h,l]) => (
        <a href={h} style="font-family:var(--f-body);font-size:10px;font-weight:700;color:var(--truffe);text-decoration:none;opacity:.6;letter-spacing:0.05em;white-space:nowrap" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.6'">{l}</a>
      ))}
    </div>
    <a href="/exposants" class="nav-links" style="font-family:var(--f-body);font-size:12px;font-weight:700;color:var(--terre);text-decoration:none;background:rgba(222,108,73,.1);border:1.5px solid rgba(222,108,73,.35);border-radius:var(--r-pill);padding:6px 12px;white-space:nowrap">Devenir exposant 🏪</a>
    <a href="#form-sponsor" class="btn btn-vert nav-cta-hide" style="font-size:13px;padding:8px 18px;white-space:nowrap">Je suis intéressé 🐾</a>
    <button id="menu-toggle" class="nav-burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════ MENU MOBILE ══ -->
<div id="mobile-nav" role="dialog" aria-label="Navigation" style="
  position:fixed;top:72px;left:16px;right:16px;z-index:98;
  background:rgba(243,241,199,.97);backdrop-filter:blur(14px);
  border:1.5px solid var(--creme-dark);border-radius:var(--r-lg);
  padding:16px;box-shadow:0 8px 32px rgba(105,50,45,.18);
  flex-direction:column;gap:2px;
">
  <a href="/" class="mobile-nav-link">← Retour au site</a>
  <div class="mobile-nav-sep"></div>
  <a href="/#pourquoi" class="mobile-nav-link" style="font-size:14px;opacity:.8">🐾 Le Woof Day</a>
  <a href="/#zones" class="mobile-nav-link" style="font-size:14px;opacity:.8">📅 Programme</a>
  <a href="/#infos" class="mobile-nav-link" style="font-size:14px;opacity:.8">📍 Infos pratiques</a>
  <a href="/exposants" class="mobile-nav-link" style="font-size:14px;opacity:.8">🏪 Devenir exposant</a>
  <div class="mobile-nav-sep"></div>
  <a href="#form-sponsor" class="btn btn-vert" style="text-align:center;margin-top:4px">Déposer ma demande 🤝</a>
</div>

<!-- HERO -->
<section style="
  min-height:88svh;padding:120px clamp(20px,5vw,40px) clamp(160px,24vw,260px);
  background:var(--vert);color:#fff;text-align:center;
  position:relative;overflow:hidden;
">
  <!-- Grandes pattes fond vert — style POSTINSTA02, opacité CSS .13 -->
  <div class="paw-mark" style="left:-6%;top:-8%;transform:rotate(-12deg)">🐾</div>
  <div class="paw-mark" style="right:-4%;top:5%;transform:rotate(18deg)">🐾</div>
  <div class="paw-float" style="--paw-dur:12s;--paw-delay:0s;bottom:5%;left:35%;font-size:clamp(100px,16vw,200px);color:rgba(255,255,255,.08);transform:rotate(-5deg);line-height:1">🐾</div>

  <!-- Logo chien fond -->
  <img src="/logos/logo-chien-blanc.svg" alt="" aria-hidden="true" style="position:absolute;left:-4%;top:50%;translate:0 -50%;width:clamp(200px,30vw,380px);opacity:.05;pointer-events:none"/>

  <!-- Contenu centré -->
  <div style="position:relative;z-index:3;max-width:700px;margin:0 auto">
    <!-- Torn paper heading avec scotch — POSTINSTA03 exact -->
    <!-- Le div définit la taille, le SVG s'étire derrière via position:absolute -->
    <div data-reveal data-delay="1" style="margin-bottom:28px;display:inline-block;position:relative;transform:rotate(-1.2deg);padding:22px 56px 44px">
      <!-- SVG torn paper — s'adapte à la taille du texte (preserveAspectRatio none) -->
      <svg style="position:absolute;inset:0;width:100%;height:100%;display:block;filter:drop-shadow(5px 7px 0px rgba(0,0,0,.22))"
           viewBox="0 0 460 180" preserveAspectRatio="none" aria-hidden="true">
        <path fill="#f5f2d0" d="
          M0,0 L460,0 L460,138
          L449,144 L440,136 L431,146 L422,137 L413,147 L404,138
          L395,148 L386,139 L377,149 L368,140 L359,150 L350,141
          L341,151 L332,142 L323,152 L314,143 L305,153 L296,144
          L287,154 L278,145 L269,155 L260,146 L251,156 L242,147
          L233,157 L224,148 L215,158 L206,149 L197,159 L188,150
          L179,160 L170,151 L161,161 L152,152 L143,160 L134,151
          L125,159 L116,150 L107,158 L98,149 L89,157 L80,148
          L71,156 L62,147 L53,155 L44,146 L35,154 L26,145
          L17,153 L8,143 L0,150 Z
        "/>
      </svg>
      <!-- Scotch haut gauche -->
      <div style="position:absolute;top:-13px;left:32px;width:54px;height:25px;background:rgba(255,220,40,.68);transform:rotate(-5deg);border-radius:2px;z-index:3;box-shadow:0 1px 4px rgba(0,0,0,.14)"></div>
      <!-- Scotch haut droite -->
      <div style="position:absolute;top:-13px;right:32px;width:54px;height:25px;background:rgba(255,220,40,.68);transform:rotate(4deg);border-radius:2px;z-index:3;box-shadow:0 1px 4px rgba(0,0,0,.14)"></div>
      <!-- Heading -->
      <h1 style="position:relative;z-index:1;font-family:var(--f-head);font-size:clamp(36px,7vw,72px);font-weight:700;line-height:1.05;color:var(--truffe);text-align:center;display:inline-block">
        DEVENIR<br/>SPONSOR !
      </h1>
    </div>
    <p data-reveal data-delay="2" style="font-family:var(--f-body);font-size:clamp(15px,2.5vw,19px);opacity:.85;max-width:52ch;margin:0 auto 28px;line-height:1.65">
      Associez votre marque à la grande fête canine de Charente. Un événement ancré, solidaire, et mémorable.
    </p>
    <div data-reveal data-delay="3" style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:32px">
      {['🐾 800 visiteurs Éd.1','🚀 1200+ visés Éd.2','🏕️ 50–60 exposants','❤️ Refuge de l\'Angoumois'].map(t => (
        <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:var(--r-pill);padding:7px 14px;font-family:var(--f-body);font-size:12px;font-weight:600">{t}</span>
      ))}
    </div>
    <div data-reveal data-delay="4" style="position:relative;display:inline-flex;isolation:isolate;margin-top:24px">
      <DoodleMark variant="circle" color="rgba(243,241,199,.72)" style="left:50%;top:50%;width:calc(100% + 78px);height:auto;translate:-50% -50%;transform:rotate(2deg)" />
      <DoodleMark variant="burst" color="var(--terre)" style="right:-34px;top:-50px;width:72px;height:auto;transform:rotate(18deg)" />
      <a href="#form-sponsor" class="btn" style="position:relative;background:rgba(255,255,255,.95);color:var(--vert);font-size:clamp(16px,2.5vw,20px);padding:18px 42px;box-shadow:0 8px 32px rgba(0,0,0,.25)">
        Déposer ma demande 🤝
      </a>
    </div>
  </div>

  <!-- Golden face2 vert — fond vert, centré bas -->
  <div class="dog-deco" style="position:absolute;bottom:clamp(-230px,-18vw,-150px);right:clamp(-170px,-8vw,-70px);width:fit-content;pointer-events:none;line-height:0;z-index:1">
    <img src="/images/dog-border-collie-nose-orange.png" alt="" aria-hidden="true"
      style="width:clamp(240px,31vw,430px);display:block;filter:drop-shadow(0 -16px 48px rgba(0,0,0,.35))" />
  </div>

  <!-- Annotation bubble gauche — style torn note like inspiration -->
  <div style="position:absolute;bottom:clamp(60px,14vw,140px);left:clamp(20px,6%,80px);z-index:4;pointer-events:none">
    <div style="font-family:var(--f-hand);font-size:clamp(13px,2vw,17px);color:rgba(255,255,255,.8);border:2.5px solid rgba(255,255,255,.4);border-radius:50%;padding:14px 24px;transform:rotate(-7deg);text-align:center;line-height:1.4;display:inline-block;position:relative">
      Booster votre image<br/>et soutenir la cause !
      <DoodleMark variant="arrow" color="white" style="position:absolute;bottom:-35px;right:-5px;width:44px;height:auto;transform:rotate(12deg);opacity:.5" />
    </div>
  </div>

  <!-- Slant bottom -->
  <div style="position:absolute;bottom:-1px;left:0;right:0;height:60px;background:var(--bg);clip-path:polygon(0 100%,100% 0,100% 100%)"></div>
</section>

<LogoTicker />

<!-- MANIFESTE -->
<section id="esprit" class="sec" style="background:var(--bg);position:relative;overflow:hidden">
  <div class="paw-mark" style="right:-4%;top:-5%;transform:rotate(22deg);opacity:.06">🐾</div>
  <div class="inner">
    <!-- Grille 2 colonnes : citation + stats -->
    <div class="resp-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(20px,4vw,48px);align-items:stretch">

      <!-- Colonne gauche : citation édition 1 + charte -->
      <div data-reveal style="display:flex;flex-direction:column;gap:16px">
        <div data-reveal style="margin-bottom:4px"><span class="chip chip-vert">Notre histoire</span></div>
        <h2 style="font-family:var(--f-head);font-size:clamp(26px,3.5vw,40px);font-weight:700;color:var(--truffe);line-height:1.15">Pourquoi<br/>c'est sérieux</h2>
        <!-- Grande citation Éd.1 -->
        <blockquote style="background:var(--truffe);color:#fff;border-radius:var(--r-xl);padding:clamp(20px,3vw,32px);position:relative;overflow:hidden;flex:1">
          <div style="font-family:var(--f-head);font-size:80px;line-height:.8;opacity:.15;position:absolute;top:8px;left:16px">"</div>
          <p style="font-family:var(--f-hand);font-size:clamp(17px,2.2vw,22px);line-height:1.6;position:relative;z-index:1;margin-bottom:16px">
            Pluie battante. Zéro expérience. 800 visiteurs quand même.
          </p>
          <p style="font-family:var(--f-body);font-size:13px;opacity:.7;position:relative;z-index:1">
            La preuve qu'il y a une vraie demande locale pour ce type d'événement.
          </p>
          <div style="margin-top:16px;font-family:var(--f-body);font-size:12px;font-weight:700;opacity:.55;text-transform:uppercase;letter-spacing:.1em;position:relative;z-index:1">— Édition 1, septembre 2024</div>
        </blockquote>
        <!-- Charte toggle -->
        <div style="background:#fff;border-radius:var(--r-lg);padding:16px 20px;border:1.5px solid var(--creme-dark)">
          <button id="toggle-manifeste" style="background:none;border:none;font-family:var(--f-body);font-size:13px;font-weight:600;color:var(--truffe);cursor:pointer;display:flex;align-items:center;gap:8px;width:100%;text-align:left">
            <span style="background:var(--vert);color:#fff;border-radius:6px;padding:3px 8px;font-size:11px">✓</span>
            Notre charte éthique ▾
          </button>
          <div id="manifeste-content" style="display:none;margin-top:12px">
            <p style="font-family:var(--f-body);font-size:13px;line-height:1.75;color:var(--truffe);opacity:.8">
              Éducation positive uniquement. Pas de méthodes coercitives, pas de produits dangereux. Sponsoriser le Woof Day, c'est s'associer à des valeurs concrètes — pas juste un logo sur une bâche.
            </p>
          </div>
        </div>
      </div>

      <!-- Colonne droite : stats Éd.2 + preuve -->
      <div data-reveal data-delay="2" style="display:flex;flex-direction:column;gap:12px">
        <!-- Stats numériques -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          {[
            { val: '800',   label: 'visiteurs Éd.1',  bg: 'var(--terre)',  color: '#fff' },
            { val: '1200+', label: 'objectif Éd.2',   bg: 'var(--bleu)',   color: 'var(--truffe)' },
            { val: '50–60', label: 'exposants',        bg: 'var(--creme)', color: 'var(--truffe)' },
            { val: '100%',  label: 'don au Refuge',   bg: 'var(--vert)',   color: '#fff' },
          ].map(s => (
            <div style={`background:${s.bg};color:${s.color};border-radius:var(--r-lg);padding:20px;text-align:center`}>
              <div style="font-family:var(--f-head);font-size:clamp(28px,4vw,40px);font-weight:700;line-height:1">{s.val}</div>
              <div style="font-family:var(--f-body);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;opacity:.75;margin-top:5px">{s.label}</div>
            </div>
          ))}
        </div>
        <!-- Éd.2 pitch -->
        <div style="background:var(--vert);color:#fff;border-radius:var(--r-xl);padding:clamp(20px,3vw,28px);flex:1;display:flex;flex-direction:column;justify-content:center;gap:10px">
          <div style="font-family:var(--f-body);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;opacity:.7">Édition 2 — La montée en puissance</div>
          <p style="font-family:var(--f-body);font-size:14px;line-height:1.75;opacity:.9">
            Nouveau site en Charente, activités aquatiques, campagne structurée. Votre marque sur une fusée en phase d'accélération.
          </p>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            {['Nouveau lieu', 'Zone aquatique', 'Comm. renforcée', '13 sept. 2026'].map(t => (
              <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.25);border-radius:var(--r-pill);padding:4px 10px;font-family:var(--f-body);font-size:11px;font-weight:600">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- LEVIERS PSYCHOLOGIQUES -->
<section id="marketing" class="sec" style="background:var(--creme);position:relative;overflow:hidden">
  <div class="paw-mark-bold" style="left:-4%;top:5%;transform:rotate(-20deg)">🐾</div>
  <div class="paw-mark-bold" style="right:-3%;bottom:-5%;transform:rotate(15deg);opacity:.18">🐾</div>
  <!-- Golden assis regardant depuis la droite -->
  <img src="/images/dog-golden-assis2-vert.png" alt="" aria-hidden="true" style="position:absolute;bottom:-30px;right:-60px;width:clamp(170px,23vw,320px);opacity:.2;pointer-events:none;transform:scaleX(-1)" />
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(28px,4vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-truffe">Pourquoi ça marche</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px);color:var(--truffe)">Ce que ça fait<br/>pour votre marque</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px">
      {[
        { icon: '✨', titre: 'Effet Halo', desc: 'Votre marque hérite de l\'émotion positive de l\'événement. Les gens associent votre nom à une belle journée.', bg: 'var(--truffe)', color: '#fff' },
        { icon: '👥', titre: 'Preuve Sociale', desc: 'Des centaines de photos de l\'événement circulent sur les réseaux. Votre logo y apparaît naturellement.', bg: 'var(--bleu)', color: 'var(--truffe)' },
        { icon: '🧠', titre: 'Mémorisation', desc: 'Une marque vue dans un contexte émotionnel fort (chiens, famille, soleil) se grave bien mieux en mémoire.', bg: 'var(--terre)', color: '#fff' },
        { icon: '🤝', titre: 'Réciprocité', desc: 'Le public sait que vous soutenez le Refuge. Il a une raison concrète de vous préférer à vos concurrents.', bg: 'var(--vert)', color: '#fff' },
      ].map((l, i) => (
        <div data-reveal data-delay={String(i + 1)} style={`background:${l.bg};color:${l.color};border-radius:var(--r-xl);padding:24px;position:relative;overflow:hidden`}>
          <div style={`font-family:var(--f-head);font-size:72px;font-weight:700;opacity:.1;position:absolute;top:-8px;right:12px;line-height:1;pointer-events:none`}>{String(i+1).padStart(2,'0')}</div>
          <div style="font-size:36px;margin-bottom:12px;position:relative;z-index:1">{l.icon}</div>
          <h3 style="font-family:var(--f-head);font-size:20px;font-weight:700;margin-bottom:8px;position:relative;z-index:1">{l.titre}</h3>
          <p style={`font-family:var(--f-body);font-size:13px;line-height:1.7;opacity:.85;position:relative;z-index:1`}>{l.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BUDGET TRANSPARENT -->
<section id="budget" class="sec" style="background:var(--truffe);color:#fff">
  <div class="inner-sm">
    <div style="text-align:center;margin-bottom:clamp(24px,4vw,40px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-creme">Transparence</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(28px,4vw,44px)">Budget transparent</h2>
      <p data-reveal data-delay="2" style="font-family:var(--f-body);font-size:15px;opacity:.8;margin-top:8px;max-width:50ch;margin-left:auto;margin-right:auto;line-height:1.65">
        Objectif sponsoring : <strong>4 000€</strong>. Voici pourquoi chaque euro compte.
      </p>
    </div>
    <div data-reveal style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:var(--r-xl);padding:clamp(24px,4vw,40px)">
