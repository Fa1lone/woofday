            </select>
          </div>
          <div>
            <label style="display:block;font-family:var(--f-body);font-size:13px;font-weight:600;color:var(--truffe);margin-bottom:6px">Stand souhaité</label>
            <select name="stand" class="field" style="background:#fff">
