---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { ActivitiesTable } from '../../components/dashboard/ActivitiesTable';
import { getFiches } from '../../lib/data';

const fiches = await getFiches();
const exposants = fiches.filter(f => f.estExposant);
const sponsors = fiches.filter(f => f.estSponsor);
const visibles = fiches.filter(f => f.visible);
---

<DashboardLayout title="Fiches Publiques" activeTab="activities">
  <div style="background:white;border-radius:20px;padding:24px;border:1.5px solid #e8e5a8;margin-bottom:24px">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px">
      <div>
        <h2 style="font-family:'Fredoka',sans-serif;margin:0;font-size:20px">Fiches publiques</h2>
        <p style="font-size:13px;opacity:.6;margin:4px 0 0">Les entités affichées sur le site (exposants & sponsors).</p>
      </div>
      <div style="display:flex;gap:20px">
        <div style="text-align:center">
          <div style="font-family:'Fredoka',sans-serif;font-size:28px;font-weight:700;color:#de6c49">{exposants.length}</div>
          <div style="font-size:11px;opacity:.6">Exposants</div>
        </div>
        <div style="text-align:center">
          <div style="font-family:'Fredoka',sans-serif;font-size:28px;font-weight:700;color:#26422b">{sponsors.length}</div>
          <div style="font-size:11px;opacity:.6">Sponsors</div>
        </div>
        <div style="text-align:center">
          <div style="font-family:'Fredoka',sans-serif;font-size:28px;font-weight:700;color:#91acda">{visibles.length}</div>
          <div style="font-size:11px;opacity:.6">Visibles</div>
        </div>
      </div>
    </div>
  </div>

  <div style="margin-bottom:20px">
    <a href="/api/export?type=fiches" download="fiches.csv" style="display:inline-flex;align-items:center;gap:8px;background:#fff;border:1.5px solid #e8e5a8;border-radius:10px;padding:8px 16px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;color:#69322d;text-decoration:none">
      📥 Export CSV fiches
    </a>
  </div>

  <ActivitiesTable initialData={fiches} client:load />
</DashboardLayout>
