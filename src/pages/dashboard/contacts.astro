---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// TODO: replace with real DB query
const contacts: any[] = [];
---

<DashboardLayout title="Contacts" activeTab="contacts">
  {contacts.length === 0 ? (
    <div style="text-align:center;padding:64px;color:#69322d;opacity:.5;font-family:'Poppins',sans-serif">
      Aucun message de contact pour l'instant.
    </div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:12px">
      {contacts.map((c: any) => (
        <div style="background:white;border-radius:16px;padding:16px 20px;border:1.5px solid #e8e5a8">
          <div style="font-family:'Fredoka',sans-serif;font-weight:700;color:#69322d">{c.nom}</div>
          <div style="font-family:'Poppins',sans-serif;font-size:13px;color:#de6c49">{c.reason}</div>
          <div style="font-family:'Poppins',sans-serif;font-size:13px;color:#69322d;opacity:.7;margin-top:6px">{c.message}</div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>
