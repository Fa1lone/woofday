---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSponsors } from '../../lib/data';

const sponsors = getSponsors();

const packLabels: Record<string, string> = {
  platine: '🥇 Platine', or: '🟡 Or', argent: '⚪ Argent', bronze: '🟤 Bronze', custom: '✨ Sur mesure',
};
const statusColors = { pending: '#f3f1c7', confirmed: '#d4edda', rejected: '#fde8e8' };
const statusLabels = { pending: '⏳ En attente', confirmed: '✅ Confirmé', rejected: '❌ Refusé' };
---

<DashboardLayout title="Sponsors" activeTab="sponsors">
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:24px">
    {[
      { val: sponsors.length, label: 'Total' },
      { val: sponsors.filter(s => s.status === 'confirmed').length, label: 'Confirmés' },
      { val: sponsors.filter(s => s.status === 'pending').length, label: 'En attente' },
    ].map(s => (
      <div style="background:white;border-radius:16px;padding:16px;border:1.5px solid #e8e5a8;text-align:center">
        <div style="font-family:'Fredoka',sans-serif;font-size:28px;font-weight:700;color:#26422b">{s.val}</div>
        <div style="font-family:'Poppins',sans-serif;font-size:11px;color:#69322d;opacity:.6;text-transform:uppercase">{s.label}</div>
      </div>
    ))}
  </div>

  {sponsors.length === 0 ? (
    <div style="text-align:center;padding:64px;color:#69322d;opacity:.4;font-family:'Poppins',sans-serif">
      Aucune demande de sponsoring pour l'instant.
    </div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:10px">
      {sponsors.slice().reverse().map(s => (
        <div style="background:white;border-radius:16px;padding:16px 20px;border:1.5px solid #e8e5a8;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-start">
          <div style="flex:1;min-width:200px">
            <div style="font-family:'Fredoka',sans-serif;font-weight:700;font-size:16px;color:#69322d">{s.entreprise}</div>
            <div style="font-family:'Poppins',sans-serif;font-size:13px;color:#69322d;opacity:.7">{s.contact}</div>
            {s.pack && <div style="font-family:'Poppins',sans-serif;font-size:12px;color:#26422b;font-weight:600;margin-top:4px">{packLabels[s.pack] ?? s.pack}</div>}
            {s.zone && <div style="font-family:'Poppins',sans-serif;font-size:12px;color:#de6c49;margin-top:2px">Naming : {s.zone}</div>}
            {s.objectif && <div style="font-family:'Poppins',sans-serif;font-size:13px;color:#69322d;opacity:.6;margin-top:6px;line-height:1.5">{s.objectif}</div>}
          </div>
          <div style="text-align:right">
            <span style={`padding:4px 12px;border-radius:9999px;font-size:12px;font-weight:600;font-family:'Poppins',sans-serif;background:${statusColors[s.status]};color:#69322d;display:inline-block;margin-bottom:8px`}>{statusLabels[s.status]}</span>
            <div><a href={`mailto:${s.email}`} style="font-family:'Poppins',sans-serif;font-size:12px;color:#91acda;text-decoration:none">{s.email}</a></div>
            <div style="font-family:'Poppins',sans-serif;font-size:11px;color:#69322d;opacity:.4;margin-top:4px">{new Date(s.createdAt).toLocaleDateString('fr-FR')}</div>
          </div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>
