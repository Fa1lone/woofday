---
import Layout from '../layouts/Layout.astro';
import { getInterestCount } from '../lib/data';
const count = getInterestCount();

const zones = [
  { emoji: '🌊', nom: 'Zone Aquatique',      desc: 'Baignade & jeux d\'eau' },
  { emoji: '🏆', nom: 'Agility & Sport',     desc: 'Parcours, démonstrations' },
  { emoji: '🌿', nom: 'Détente & Zen',       desc: 'Massages canins, relaxation' },
  { emoji: '👶', nom: 'Famille & Kids',      desc: 'Ateliers, animations enfants' },
  { emoji: '🎤', nom: 'Scène Centrale',      desc: 'Spectacles, concours, remises' },
  { emoji: '🌱', nom: 'Village Bien-Être',   desc: 'Santé naturelle & alimentation' },
];

const faqs = [
  { q: "Le Woof Day est-il payant ?",         a: "Non, l'entrée est totalement gratuite." },
  { q: "Puis-je venir avec mon chien ?",       a: "Oui, les chiens sont les bienvenus, tenus en laisse." },
  { q: "Où a lieu le Woof Day ?",              a: "À Ambérac, près d'Angoulême, en Charente (16)." },
  { q: "Quand a lieu le Woof Day ?",           a: "Le dimanche 13 septembre 2026, de 10h à 18h." },
  { q: "Est-ce réservé aux passionnés ?",      a: "Non. Le Woof Day est ouvert à tous — avec ou sans chien." },
  { q: "Y aura-t-il des activités ?",          a: "Oui : 50+ exposants, animations, concours, tombola, activités aquatiques." },
  { q: "Le Woof Day soutient-il une cause ?",  a: "Oui. 100% des bénéfices nets reversés au Refuge de l'Angoumois." },
  { q: "Où suivre les annonces ?",             a: "Sur Instagram @woofday_charente et sur ce site." },
];
---

<Layout>
<div id="pbar" style="width:0%"></div>

<!-- ═══════════════════════════════════════════════════ NAV ══ -->
<nav id="nav" style="
  position: fixed; top: 16px; left: 50%; translate: -50% 0;
  z-index: 100; width: min(calc(100% - 32px), 1100px);
  background: rgba(243,241,199,.92); backdrop-filter: blur(12px);
  border: 1.5px solid var(--creme-dark); border-radius: var(--r-pill);
  padding: 10px 20px; display: flex; align-items: center; justify-content: space-between;
  transition: box-shadow .3s;
">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <img src="/logos/tete-chien.svg" alt="" style="height:32px;width:32px;object-fit:contain" />
    <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
  </a>
  <div id="nav-links" style="display:flex;align-items:center;gap:28px" class="hidden md:flex">
    {[['#concept','L\'événement'],['#zones','Zones'],['#infos','Infos'],['#contact','Contact']].map(([h,l]) => (
      <a href={h} style="font-family:var(--f-body);font-size:14px;font-weight:600;color:var(--truffe);text-decoration:none;opacity:.8;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.8'">{l}</a>
    ))}
  </div>
  <a href="#contact" class="btn btn-terre" style="font-size:14px;padding:10px 22px">Je viens 🐾</a>
</nav>

<!-- ═══════════════════════════════════════════════════ HERO ══ -->
<section style="
  min-height: 100svh; background: var(--terre); color: #fff;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 120px clamp(20px,5vw,40px) 80px;
  position: relative; overflow: hidden;
">
  <!-- Picto chien décoratif en fond -->
  <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="
    position: absolute; right: -8%; bottom: -10%;
    width: clamp(280px, 45vw, 560px); opacity: .1;
    filter: brightness(0) invert(1); transform: rotate(-12deg);
    pointer-events: none; user-select: none;
  "/>

  <div style="position:relative;z-index:2;max-width:780px">
    <div data-reveal style="margin-bottom:24px">
      <span class="chip chip-white">🐾 Édition 2 — Charente (16)</span>
    </div>

    <!-- Logo principal -->
    <div data-reveal data-delay="1" style="margin-bottom:16px">
      <img src="/logos/logo-couleur.svg" alt="Woof Day" style="height:clamp(80px,16vw,160px);filter:brightness(0) invert(1);drop-shadow:0 4px 24px rgba(0,0,0,.2)" />
    </div>

    <p data-reveal data-delay="2" style="
      font-family:var(--f-head); font-size:clamp(22px,4vw,34px); font-weight:500;
      opacity:.9; margin-bottom:32px; line-height:1.25;
    ">La grande fête canine de Charente</p>

    <!-- Date band -->
    <div data-reveal data-delay="2" style="
      display:inline-flex; align-items:center; gap:24px; flex-wrap:wrap; justify-content:center;
      background:rgba(0,0,0,.18); border-radius:var(--r-md); padding:14px 28px; margin-bottom:40px;
      font-family:var(--f-body); font-size:14px; font-weight:600; opacity:.95;
    ">
      <span>📅 Dimanche 13 septembre 2026</span>
      <span style="opacity:.4">|</span>
      <span>🕙 10h – 18h</span>
      <span style="opacity:.4">|</span>
      <span>📍 Ambérac, Charente (16)</span>
      <span style="opacity:.4">|</span>
      <span style="color:var(--creme)">✅ Gratuit</span>
    </div>

    <!-- Countdown -->
    <div id="countdown" data-reveal data-delay="3" style="display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:40px"></div>

    <!-- CTA -->
    <div data-reveal data-delay="3" style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:40px">
      <button id="btn-participe" class="btn btn-truffe" style="font-size:clamp(15px,2.5vw,20px);padding:16px 36px">
        Je participe ! 🐾
      </button>
      <a href="/exposants" class="btn btn-outline-w" style="font-size:clamp(14px,2vw,18px)">Devenir exposant</a>
    </div>

    <!-- Compteur intéressés -->
    <div id="interest-block" data-reveal data-delay="4" style="
      display:inline-flex; align-items:center; gap:14px;
      background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25);
      border-radius:var(--r-md); padding:12px 24px;
      transition: transform .25s;
    ">
      <div style="display:flex;align-items:center;gap:-4px">
        {['🐕','🐩','🦮'].map(d => (
          <span style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);display:inline-flex;align-items:center;justify-content:center;font-size:16px;margin-right:-6px;border:2px solid rgba(255,255,255,.3)">{d}</span>
        ))}
      </div>
      <div>
        <span id="interest-count" style="font-family:var(--f-head);font-size:26px;font-weight:700;color:var(--creme)">{count}</span>
        <span style="font-family:var(--f-body);font-size:13px;opacity:.8"> personnes intéressées</span>
      </div>
    </div>

    <!-- Annotation Kalam -->
    <p data-reveal data-delay="4" style="font-family:var(--f-hand);font-size:18px;opacity:.7;margin-top:16px;transform:rotate(-1.5deg)">
      ...et le chiffre monte chaque jour ! 🐾
    </p>
  </div>

  <!-- Slant bottom -->
  <div style="position:absolute;bottom:-1px;left:0;right:0;height:60px;background:var(--bg);clip-path:polygon(0 100%,100% 0,100% 100%)"></div>
</section>

<!-- ═════════════════════════════════════════════════ CONCEPT ══ -->
<section id="concept" class="sec" style="background:var(--bg)">
  <div class="inner" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,6vw,80px);align-items:center">
    <div>
      <div data-reveal style="margin-bottom:20px"><span class="chip chip-terre">L'événement</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,58px);color:var(--truffe);margin-bottom:24px">
        Qu'est-ce que le<br/><span style="color:var(--terre)">Woof Day ?</span>
      </h2>
      <p data-reveal data-delay="2" style="font-size:16px;line-height:1.8;color:var(--truffe);opacity:.8;max-width:52ch;margin-bottom:28px">
        Une fête ouverte à tous — avec ou sans chien — pour découvrir, échanger et profiter ensemble. Exposants passionnés, animations, concours, bien-être canin.
      </p>
      <ul data-reveal data-delay="2" style="list-style:none;padding:0;display:flex;flex-direction:column;gap:12px;margin-bottom:32px">
        {[
          ['🏪', 'Ateliers et activités canines'],
          ['🤝', 'Rencontre d\'experts passionnés'],
          ['💆', 'Bien-être et convivialité'],
          ['❤️', 'Au profit du Refuge de l\'Angoumois'],
        ].map(([ic, tx]) => (
          <li style="display:flex;align-items:center;gap:12px;font-family:var(--f-body);font-size:15px;font-weight:500;color:var(--truffe)">
            <span style="font-size:20px;width:32px;flex-shrink:0">{ic}</span>{tx}
          </li>
        ))}
      </ul>
      <div data-reveal data-delay="3">
        <a href="/exposants" class="btn btn-vert" style="margin-right:12px">Devenir exposant</a>
        <a href="/sponsor" class="btn btn-outline-t">Devenir sponsor</a>
      </div>
    </div>

    <!-- Right: Big dog icon + stamp -->
    <div data-reveal data-delay="1" style="display:flex;flex-direction:column;align-items:center;gap:24px">
      <div style="position:relative;width:100%;max-width:360px">
        <div style="background:var(--creme);border-radius:var(--r-xl);padding:48px;display:flex;align-items:center;justify-content:center">
          <img src="/logos/tete-chien.svg" alt="" style="width:100%;max-width:220px;opacity:.9" />
        </div>
        <div style="position:absolute;bottom:-16px;right:-16px;background:var(--vert);border-radius:var(--r-lg);padding:14px 20px;color:#fff;font-family:var(--f-head);font-size:14px;font-weight:600;box-shadow:0 8px 24px rgba(38,66,43,.3)">
          ❤️ Refuge de l'Angoumois
        </div>
      </div>
      <p style="font-family:var(--f-hand);font-size:20px;color:var(--terre);transform:rotate(-2deg);text-align:center">100% des bénéfices nets reversés !</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════ ZONES ══ -->
<section id="zones" class="sec slant-b" style="background:var(--vert);color:#fff;margin-bottom:0">
  <div class="inner">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:clamp(32px,5vw,56px)">
      <div>
        <div data-reveal style="margin-bottom:16px"><span class="chip chip-white">Programme</span></div>
        <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,58px)">Les zones<br/>de l'événement</h2>
      </div>
      <p data-reveal data-delay="2" style="font-family:var(--f-hand);font-size:22px;opacity:.7;transform:rotate(-1.5deg);max-width:200px;text-align:right">
        une journée,<br/>6 mondes !
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px">
      {zones.map((z, i) => (
        <div data-reveal data-delay={String(i % 3 + 1)} style="
          background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15);
          border-radius:var(--r-lg); padding:28px 24px;
          transition: background .25s, transform .25s;
        " onmouseover="this.style.background='rgba(255,255,255,.14)';this.style.transform='translateY(-4px)'" onmouseout="this.style.background='rgba(255,255,255,.08)';this.style.transform=''">
          <div style="font-size:36px;margin-bottom:12px">{z.emoji}</div>
          <h3 style="font-family:var(--f-head);font-size:20px;font-weight:700;margin-bottom:6px">{z.nom}</h3>
          <p style="font-family:var(--f-body);font-size:14px;opacity:.65;line-height:1.6">{z.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════ EXPOSANTS TEASER ══ -->
<section class="sec" style="background:var(--creme);padding-top:clamp(80px,12vw,140px)">
  <div class="inner" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,6vw,80px);align-items:center">
    <div data-reveal style="
      background:var(--truffe);border-radius:var(--r-xl);padding:clamp(32px,5vw,56px);
      color:#fff;position:relative;overflow:hidden;
    ">
      <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="position:absolute;right:-10%;bottom:-15%;width:55%;opacity:.07;filter:brightness(0) invert(1);pointer-events:none"/>
      <div style="position:relative;z-index:1">
        <span class="chip chip-terre" style="margin-bottom:20px">Exposants</span>
        <h3 style="font-family:var(--f-head);font-size:clamp(28px,4vw,40px);margin-bottom:16px">Vous avez une activité liée au chien ?</h3>
        <p style="font-family:var(--f-body);font-size:15px;opacity:.8;line-height:1.7;margin-bottom:28px">
          Réservez votre stand pour l'édition 2 et rencontrez des centaines d'amoureux des animaux.
        </p>
        <a href="/exposants" class="btn btn-terre">Candidater comme exposant 🏪</a>
      </div>
    </div>
    <div data-reveal data-delay="2" style="
      background:var(--bleu);border-radius:var(--r-xl);padding:clamp(32px,5vw,56px);
      color:var(--truffe);position:relative;overflow:hidden;
    ">
      <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="position:absolute;right:-10%;bottom:-15%;width:55%;opacity:.1;pointer-events:none"/>
      <div style="position:relative;z-index:1">
        <span class="chip chip-truffe" style="margin-bottom:20px">Sponsors</span>
        <h3 style="font-family:var(--f-head);font-size:clamp(28px,4vw,40px);margin-bottom:16px">Votre marque visible par toute la Charente</h3>
        <p style="font-family:var(--f-body);font-size:15px;opacity:.8;line-height:1.7;margin-bottom:28px">
          Associez votre image à une journée positive, solidaire, mémorable.
        </p>
        <a href="/sponsor" class="btn btn-truffe">Devenir sponsor 🤝</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════ INFOS ══ -->
<section id="infos" class="sec" style="background:var(--bg)">
  <div class="inner">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:clamp(32px,5vw,56px)">
      <div>
        <div data-reveal style="margin-bottom:16px"><span class="chip chip-vert">Infos pratiques</span></div>
        <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,58px);color:var(--truffe)">Tout savoir<br/>avant de venir</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:32px">
      {[
        { icon: '📅', label: 'Date',     val: 'Dimanche 13 sept. 2026', bg: 'var(--terre)', color: '#fff' },
        { icon: '🕙', label: 'Horaires', val: '10h – 18h',              bg: 'var(--vert)',  color: '#fff' },
        { icon: '📍', label: 'Lieu',     val: 'Ambérac, Charente (16)', bg: 'var(--creme)', color: 'var(--truffe)' },
        { icon: '🎫', label: 'Tarif',    val: 'Entrée gratuite',        bg: 'var(--truffe)',color: '#fff' },
      ].map((info, i) => (
        <div data-reveal data-delay={String(i + 1)} style={`background:${info.bg};color:${info.color};border-radius:var(--r-lg);padding:28px 24px;`}>
          <div style="font-size:32px;margin-bottom:8px">{info.icon}</div>
          <div style="font-family:var(--f-body);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;opacity:.6;margin-bottom:4px">{info.label}</div>
          <div style="font-family:var(--f-head);font-size:20px;font-weight:700">{info.val}</div>
        </div>
      ))}
    </div>

    <!-- Map placeholder -->
    <div data-reveal style="background:var(--creme);border-radius:var(--r-lg);overflow:hidden;height:280px;position:relative">
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=-0.3%2C45.6%2C-0.0%2C45.8&layer=mapnik&marker=45.7%2C-0.15"
        style="width:100%;height:100%;border:none;opacity:.85"
        title="Carte Ambérac"
        loading="lazy"
      ></iframe>
      <div style="position:absolute;top:16px;left:16px;background:var(--truffe);color:#fff;padding:10px 18px;border-radius:var(--r-pill);font-family:var(--f-head);font-size:14px;font-weight:600;box-shadow:0 4px 16px rgba(0,0,0,.2)">
        📍 Ambérac, 16 — Parking gratuit
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════ FAQ ══ -->
<section id="faq" class="sec" style="background:var(--vert);color:#fff">
  <div class="inner-sm">
    <div style="text-align:center;margin-bottom:clamp(32px,5vw,56px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-white">FAQ</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,52px)">Questions fréquentes</h2>
    </div>

    <div style="display:flex;flex-direction:column;gap:10px" id="faq-list">
      {faqs.map((f, i) => (
        <div class="faq-item" data-reveal data-delay={String((i % 3) + 1)} style="border-radius:var(--r-md);overflow:hidden;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15)">
          <button class="faq-btn" style="width:100%;display:flex;justify-content:space-between;align-items:center;padding:18px 22px;gap:12px;background:none;border:none;cursor:pointer;font-family:var(--f-body);font-weight:600;font-size:15px;color:#fff;text-align:left">
            <span>{f.q}</span>
            <span class="faq-chevron" style="flex-shrink:0;width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:14px;transition:transform .25s">▾</span>
          </button>
          <div class="faq-body" style="display:none;padding:0 22px 18px;font-family:var(--f-body);font-size:14px;line-height:1.75;opacity:.75;color:#fff">
            {f.a}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════ CONTACT ══ -->
<section id="contact" class="sec" style="background:var(--creme)">
  <div class="inner-sm">
    <div style="text-align:center;margin-bottom:clamp(32px,5vw,48px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-terre">Contact</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,52px);color:var(--truffe)">Restons en contact !</h2>
      <p data-reveal data-delay="2" style="font-family:var(--f-body);font-size:16px;color:var(--truffe);opacity:.7;margin-top:10px">
        Vous souhaitez venir, aider, proposer une idée ? On vous répond vite.
      </p>
    </div>

    <form id="contact-form" data-reveal data-delay="2" style="background:#fff;border-radius:var(--r-xl);padding:clamp(24px,5vw,48px);box-shadow:0 8px 40px rgba(105,50,45,.1);border:1.5px solid var(--creme-dark)">
      <div style="display:grid;gap:14px">
        <div>
          <label style="display:block;font-family:var(--f-body);font-size:13px;font-weight:600;color:var(--truffe);margin-bottom:6px">Je souhaite…</label>
          <select name="reason" required class="field" style="background:var(--bg)">
            <option value="">Choisir une raison…</option>
            <option value="venir">Venir à l'événement</option>
            <option value="benevole">Être bénévole</option>
            <option value="idee">Proposer une idée</option>
            <option value="info">Être tenu informé</option>
            <option value="affiche">Demander des affiches</option>
            <option value="pro">Devenir Exposant / Sponsor</option>
          </select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <input name="nom" placeholder="Votre nom" required class="field" />
          <input name="email" type="email" placeholder="Email" required class="field" />
        </div>
        <textarea name="message" placeholder="Votre message (optionnel)" rows="3" class="field" style="resize:none"></textarea>
        <button type="submit" class="btn btn-terre" style="width:100%;font-size:18px;padding:16px">
          Envoyer 🐾
        </button>
        <div id="contact-success" style="display:none;text-align:center;padding:16px;background:var(--vert);color:#fff;border-radius:var(--r-md);font-family:var(--f-head);font-size:17px;font-weight:600">
          ✅ Message envoyé ! On vous répond sous 48h.
        </div>
      </div>
    </form>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════ FOOTER ══ -->
<footer style="background:var(--truffe);color:#fff;padding:clamp(40px,6vw,64px) clamp(20px,5vw,40px)">
  <div class="inner" style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:24px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:14px">
      <img src="/logos/tete-chien.svg" alt="" style="height:44px;filter:brightness(0) invert(1);opacity:.9"/>
      <div>
        <div style="font-family:var(--f-head);font-size:20px;font-weight:700">Woof Day</div>
        <div style="font-family:var(--f-body);font-size:12px;opacity:.5;margin-top:2px">Événements canins · Charente (16)</div>
      </div>
    </div>
    <nav style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;justify-content:center">
      {[['/', 'Accueil'],['/exposants','Exposants'],['/sponsor','Sponsors'],['https://instagram.com/woofday_charente','Instagram ↗']].map(([href, label]) => (
        <a href={href} target={href.startsWith('http') ? '_blank' : '_self'} rel="noopener" style="font-family:var(--f-body);font-size:13px;color:rgba(255,255,255,.55);text-decoration:none;transition:color .2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.55)'">{label}</a>
      ))}
    </nav>
    <div style="text-align:right;font-family:var(--f-body);font-size:12px;opacity:.4">© 2026 Woof Day</div>
  </div>
</footer>
</Layout>

<script>
  import confetti from 'canvas-confetti';

  // Progress bar
  window.addEventListener('scroll', () => {
    const el = document.getElementById('pbar');
    if (!el) return;
    const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100;
    el.style.width = pct + '%';
  });

  // Countdown
  function tick() {
    const diff = new Date('2026-09-13T10:00:00').getTime() - Date.now();
    if (diff <= 0) return;
    const parts = [
      { v: Math.floor(diff / 86400000),              l: 'Jours'  },
      { v: Math.floor(diff % 86400000 / 3600000),    l: 'Heures' },
      { v: Math.floor(diff % 3600000  / 60000),      l: 'Min'    },
      { v: Math.floor(diff % 60000    / 1000),       l: 'Sec'    },
    ];
    const el = document.getElementById('countdown');
    if (!el) return;
    el.innerHTML = parts.map(({ v, l }) => `
      <div style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:16px;padding:12px 10px 10px;min-width:68px;text-align:center">
        <div style="font-family:'Fredoka',sans-serif;font-size:clamp(26px,5vw,40px);font-weight:700;line-height:1;color:var(--creme)">${String(v).padStart(2,'0')}</div>
        <div style="font-family:'Poppins',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;opacity:.6;margin-top:4px">${l}</div>
      </div>
    `).join('');
  }
  tick(); setInterval(tick, 1000);

  // Animate count
  function animCount(el: HTMLElement, from: number, to: number) {
    const t0 = performance.now();
    const run = (now: number) => {
      const p = Math.min((now - t0) / 900, 1);
      el.textContent = Math.round(from + (to - from) * (1 - Math.pow(1 - p, 3))).toString();
      if (p < 1) requestAnimationFrame(run);
    };
    requestAnimationFrame(run);
  }

  // "Je participe" button
  const btn = document.getElementById('btn-participe') as HTMLButtonElement;
  const countEl = document.getElementById('interest-count') as HTMLElement;
  let voted = localStorage.getItem('wd_v') === '1';

  if (voted) { btn.textContent = '✅ Je participe !'; (btn as HTMLElement).style.background = '#26422b'; }

  btn?.addEventListener('click', async () => {
    if (voted) { document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' }); return; }
    const colors = ['#69322d','#de6c49','#26422b','#91acda','#f3f1c7'];
    confetti({ particleCount: 90, spread: 75, origin: { y: 0.45 }, colors });
    setTimeout(() => confetti({ particleCount: 45, angle: 60,  spread: 60, origin: { x: 0,   y: 0.5 }, colors }), 180);
    setTimeout(() => confetti({ particleCount: 45, angle: 120, spread: 60, origin: { x: 1,   y: 0.5 }, colors }), 300);
    try {
      const res = await fetch('/api/interest', { method: 'POST' });
      const { count } = await res.json();
      animCount(countEl, parseInt(countEl.textContent ?? '0'), count);
      localStorage.setItem('wd_v', '1');
      voted = true;
      btn.textContent = '✅ Je participe !';
      (btn as HTMLElement).style.background = '#26422b';
      const block = document.getElementById('interest-block') as HTMLElement;
      block.style.transform = 'scale(1.06)';
      setTimeout(() => block.style.transform = '', 320);
    } catch {}
  });

  // FAQ
  document.querySelectorAll('.faq-btn').forEach(b => {
    b.addEventListener('click', () => {
      const item = b.closest('.faq-item') as HTMLElement;
      const body = item.querySelector('.faq-body') as HTMLElement;
      const chev = item.querySelector('.faq-chevron') as HTMLElement;
      const open = body.style.display !== 'none';
      body.style.display = open ? 'none' : 'block';
      chev.style.transform = open ? '' : 'rotate(180deg)';
      item.style.background = open ? 'rgba(255,255,255,.08)' : 'rgba(255,255,255,.14)';
    });
  });

  // Contact form
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('contact-success') as HTMLElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    submitBtn.textContent = 'Envoi…'; submitBtn.disabled = true;
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form))) });
      if (res.ok) { form.style.display = 'none'; success.style.display = 'block'; }
      else throw new Error();
    } catch { submitBtn.textContent = '❌ Erreur — Réessayez'; submitBtn.disabled = false; }
  });
</script>
