---
import Layout from '../layouts/Layout.astro';
import { getInterestCount } from '../lib/data';
const count = getInterestCount();

const gcalUrl = "https://calendar.google.com/calendar/render?action=TEMPLATE&text=Woof+Day+2026&dates=20260913T080000Z/20260913T160000Z&details=La+grande+f%C3%AAte+canine+de+Charente+%E2%80%94+Entr%C3%A9e+gratuite+%F0%9F%90%BE&location=Amb%C3%A9rac%2C+Charente+(16)&sf=true&output=xml";

const exposantsFictifs = [
  { emoji: '🦴', nom: 'Caninéo Santé', activite: 'Alimentation & Friandises', color: '#de6c49',
    photo: 'https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=120&h=120&q=80&fit=crop',
    desc: 'Alimentation naturelle et locale pour chiens. Croquettes artisanales, friandises sans additifs, compléments santé.',
    long: 'Caninéo Santé propose une gamme complète d\'alimentation naturelle pour chiens, fabriquée localement en Charente. Friandises sans additifs, croquettes artisanales, compléments santé, barf. Conseils personnalisés sur place.',
    instagram: '@cadineo_sante' },
  { emoji: '🧶', nom: 'Doggy Toys 16', activite: 'Créateur Accessoires', color: '#26422b',
    photo: 'https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=120&h=120&q=80&fit=crop',
    desc: 'Accessoires, laisses et jouets éco-responsables fabriqués à la main. Chaque pièce est unique.',
    long: 'Doggy Toys 16 crée des accessoires canins éco-responsables : laisses, colliers, harnais et jouets en matières naturelles. Fabrication artisanale, zéro plastique. Personnalisation sur commande.',
    instagram: '@doggytoys16' },
  { emoji: '🌊', nom: 'Aqua Dog Charente', activite: 'Activités Sportives', color: '#91acda',
    photo: 'https://images.unsplash.com/photo-1518717758536-85ae29035b6d?w=120&h=120&q=80&fit=crop',
    desc: 'Spécialistes des activités aquatiques canines. Initiations, séances en groupe, bains sécurisés.',
    long: 'Aqua Dog Charente est le référent régional pour les activités aquatiques canines. Initiations à la natation, séances de balnéo, hydrotherapy, dock diving. Éducateurs diplômés, chiens de tous niveaux acceptés.',
    instagram: '@aquadog_charente' },
  { emoji: '🎓', nom: 'Truffes & Co', activite: 'Éducation & Comportement', color: '#69322d',
    photo: 'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=120&h=120&q=80&fit=crop',
    desc: 'Éducation canine positive. Démonstrations et ateliers en direct. Sans contrainte ni punition.',
    long: 'Truffes & Co pratique une éducation 100% positive basée sur le renforcement. Démonstrations d\'agility, ateliers pratiques, conseils comportement. Éducatrice certifiée CFPPA, approche bienveillante.',
    instagram: '@truffesandco' },
  { emoji: '🤲', nom: 'Pattes de Velours', activite: 'Ostéopathie Canine', color: '#de6c49',
    photo: 'https://images.unsplash.com/photo-1552053831-71594a27632d?w=120&h=120&q=80&fit=crop',
    desc: 'Séances de massage canin et d\'ostéopathie. Détente et récupération pour votre chien.',
    long: 'Pattes de Velours propose des soins de bien-être canin : massages relaxants, ostéopathie animale, physiothérapie. Consultation sur place le jour J avec démonstration. Diplômée en ostéopathie animale.',
    instagram: '@pattesdeVelours' },
  { emoji: '📸', nom: 'Clic Clac Dog', activite: 'Photographie Animale', color: '#26422b',
    photo: 'https://images.unsplash.com/photo-1537151608828-ea2b11777ee8?w=120&h=120&q=80&fit=crop',
    desc: 'Portraits professionnels de votre chien. Séances flash le jour J, photos retouchées livrées sous 48h.',
    long: 'Clic Clac Dog réalise des portraits photo professionnels de votre chien sur fond neutre ou en décor naturel. Séances flash de 10 min, rendu garanti sous 48h par email. Tirage possible sur demande.',
    instagram: '@clicclacdogphoto' },
];

const zones = [
  { emoji: '🌊', nom: 'Zone Aquatique',    desc: 'Baignade & jeux d\'eau' },
  { emoji: '🏆', nom: 'Agility & Sport',   desc: 'Parcours, démonstrations' },
  { emoji: '🌿', nom: 'Détente & Zen',     desc: 'Massages canins, relaxation' },
  { emoji: '👶', nom: 'Famille & Kids',    desc: 'Ateliers, animations enfants' },
  { emoji: '🎤', nom: 'Scène Centrale',    desc: 'Spectacles, concours, remises' },
  { emoji: '🌱', nom: 'Village Bien-Être', desc: 'Santé naturelle & alimentation' },
];

const faqs = [
  { q: "Le Woof Day est-il payant ?",         a: "Non, l'entrée est totalement gratuite." },
  { q: "Puis-je venir avec mon chien ?",       a: "Oui, les chiens sont les bienvenus, tenus en laisse." },
  { q: "Où a lieu le Woof Day ?",              a: "À Ambérac, près d'Angoulême, en Charente (16)." },
  { q: "Quand a lieu le Woof Day ?",           a: "Le dimanche 13 septembre 2026, de 10h à 18h." },
  { q: "Est-ce réservé aux passionnés ?",      a: "Non. Le Woof Day est ouvert à tous — avec ou sans chien." },
  { q: "Y aura-t-il des activités ?",          a: "Oui : 50+ exposants, animations, concours, tombola, activités aquatiques." },
  { q: "Le Woof Day soutient-il une cause ?",  a: "Oui. 100% des bénéfices nets reversés au Refuge de l'Angoumois." },
  { q: "Où suivre les annonces ?",             a: "Sur Instagram @woofday_charente et sur ce site." },
];

const waText = encodeURIComponent("Woof Day 2026 — Dimanche 13 sept à Ambérac ! Entrée gratuite 🐾 woofday.fr");
---

<Layout>
<div id="pbar" style="width:0%"></div>

<!-- ═══════════════════════════════════════════════════ NAV ══ -->
<nav id="nav" style="
  position: fixed; top: 16px; left: 50%; translate: -50% 0;
  z-index: 100; width: min(calc(100% - 32px), 1100px);
  background: rgba(243,241,199,.92); backdrop-filter: blur(12px);
  border: 1.5px solid var(--creme-dark); border-radius: var(--r-pill);
  padding: 10px 20px; display: flex; align-items: center; justify-content: space-between;
  transition: box-shadow .3s;
">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <img src="/logos/tete-chien.svg" alt="" style="height:32px;width:32px;object-fit:contain" />
    <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
  </a>
  <div class="nav-links" style="display:flex;align-items:center;gap:20px">
    {[['#pourquoi','L\'événement'],['#infos','Infos'],['#contact','Contact']].map(([h,l]) => (
      <a href={h} style="font-family:var(--f-body);font-size:14px;font-weight:600;color:var(--truffe);text-decoration:none;opacity:.8;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.8'">{l}</a>
    ))}
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <div class="nav-pro-links" style="display:flex;align-items:center;gap:6px">
      <a href="/exposants" style="font-family:var(--f-body);font-size:13px;font-weight:700;color:var(--terre);text-decoration:none;background:rgba(222,108,73,.1);border:1.5px solid rgba(222,108,73,.35);border-radius:var(--r-pill);padding:7px 14px;transition:background .2s" onmouseover="this.style.background='rgba(222,108,73,.2)'" onmouseout="this.style.background='rgba(222,108,73,.1)'">Exposant 🏪</a>
      <a href="/sponsor" style="font-family:var(--f-body);font-size:13px;font-weight:700;color:var(--vert);text-decoration:none;background:rgba(38,66,43,.1);border:1.5px solid rgba(38,66,43,.3);border-radius:var(--r-pill);padding:7px 14px;transition:background .2s" onmouseover="this.style.background='rgba(38,66,43,.2)'" onmouseout="this.style.background='rgba(38,66,43,.1)'">Sponsor 🤝</a>
    </div>
    <a href="#contact" id="btn-viens" class="btn btn-terre" style="font-size:14px;padding:10px 22px">Je viens 🐾</a>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════ HERO ══ -->
<section style="
  min-height: 100svh; background: var(--terre); color: #fff;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 120px clamp(20px,5vw,40px) 80px;
  position: relative; overflow: hidden;
">
  <!-- Picto chien décoratif en fond -->
  <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="
    position: absolute; right: -8%; bottom: -10%;
    width: clamp(280px, 45vw, 560px); opacity: .1;
    filter: brightness(0) invert(1); transform: rotate(-12deg);
    pointer-events: none; user-select: none;
  "/>

  <!-- Pattes flottantes -->
  <div class="paw-float" style="--paw-dur:7s;--paw-delay:0s;top:15%;left:8%;font-size:28px;color:rgba(255,255,255,.12);transform:rotate(-15deg)">🐾</div>
  <div class="paw-float" style="--paw-dur:9s;--paw-delay:1.5s;top:25%;right:7%;font-size:20px;color:rgba(255,255,255,.1);transform:rotate(20deg)">🐾</div>
  <div class="paw-float" style="--paw-dur:8s;--paw-delay:0.8s;top:60%;left:12%;font-size:22px;color:rgba(255,255,255,.09);transform:rotate(-8deg)">🐾</div>
  <div class="paw-float" style="--paw-dur:6s;--paw-delay:2s;top:72%;right:11%;font-size:18px;color:rgba(255,255,255,.08);transform:rotate(12deg)">🐾</div>
  <div class="paw-float" style="--paw-dur:10s;--paw-delay:3s;top:42%;left:4%;font-size:16px;color:rgba(255,255,255,.08);transform:rotate(-20deg)">🐾</div>

  <!-- Logo chien en fond, grand, visible -->
  <img src="/logos/logo-chien-blanc.svg" alt="" aria-hidden="true" style="
    position:absolute;left:-6%;bottom:-8%;
    width:clamp(240px,40vw,500px);opacity:.08;
    pointer-events:none;user-select:none;transform:rotate(10deg);
  "/>

  <!-- Sticker badge tournant -->
  <div style="position:absolute;top:clamp(76px,11vw,130px);right:clamp(16px,5%,80px);z-index:4">
    <img src="/images/sticker-woofd.svg" alt="Woof Day" class="stamp-spin float-sticker"
      style="width:clamp(64px,9vw,110px);opacity:.82;filter:brightness(0) invert(1)" />
  </div>

  <!-- Flèche annotation "c'est gratuit !" -->
  <div class="arrow-deco" style="bottom:clamp(90px,14vw,170px);left:clamp(20px,7%,110px)">
    <div class="arrow-note" style="color:rgba(255,255,255,.65);transform:rotate(-8deg)">
      <svg width="52" height="40" viewBox="0 0 52 40" fill="none">
        <path d="M6 6 C14 4 32 12 46 34" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" fill="none"/>
        <path d="M46 34 L37 29" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M46 34 L43 42" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
      c'est gratuit !
    </div>
  </div>

  <!-- Flèche annotation "13 sept" côté droit -->
  <div class="arrow-deco" style="bottom:clamp(60px,10vw,120px);right:clamp(20px,7%,120px)">
    <div class="arrow-note" style="color:rgba(255,255,255,.5);transform:rotate(6deg);text-align:right">
      marque le 13 sept !
      <svg width="48" height="36" viewBox="0 0 48 36" fill="none">
        <path d="M42 6 C34 4 16 12 4 30" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M4 30 L13 25" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M4 30 L7 38" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <div style="position:relative;z-index:2;max-width:800px">
    <!-- Logo principal -->
    <div data-reveal style="margin-bottom:20px">
      <img src="/logos/logo-couleur.svg" alt="Woof Day" style="height:clamp(80px,16vw,160px);filter:brightness(0) invert(1);drop-shadow:0 4px 24px rgba(0,0,0,.2)" />
    </div>

    <p data-reveal data-delay="1" style="
      font-family:var(--f-head); font-size:clamp(22px,4vw,34px); font-weight:500;
      opacity:.9; margin-bottom:24px; line-height:1.25;
    ">La grande fête canine de Charente</p>

    <!-- Proof pills -->
    <div data-reveal data-delay="1" style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:28px">
      {['✓ Entrée gratuite','🐕 Avec ou sans chien','⛺ 50+ stands','👥 1200+ visiteurs visés','❤️ Solidaire'].map(t => (
        <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:var(--r-pill);padding:6px 14px;font-family:var(--f-body);font-size:12px;font-weight:600">{t}</span>
      ))}
    </div>

    <!-- Date band -->
    <div data-reveal data-delay="2" style="
      display:inline-flex; align-items:center; gap:20px; flex-wrap:wrap; justify-content:center;
      background:rgba(0,0,0,.18); border-radius:var(--r-md); padding:14px 28px; margin-bottom:36px;
      font-family:var(--f-body); font-size:14px; font-weight:600; opacity:.95;
    ">
      <span id="rn-date">📅 Dimanche 13 septembre 2026</span>
      <span style="opacity:.4">|</span>
      <span>🕙 10h – 18h</span>
      <span style="opacity:.4">|</span>
      <span>📍 Ambérac, Charente (16)</span>
    </div>

    <!-- Countdown -->
    <div id="countdown" data-reveal data-delay="3" style="display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:36px"></div>

    <!-- CTA buttons -->
    <div data-reveal data-delay="3" style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:24px">
      <button id="btn-participe" class="btn btn-truffe" style="font-size:clamp(15px,2.5vw,20px);padding:16px 36px">
        Je participe ! 🐾
      </button>
      <a href="/exposants" class="btn btn-outline-w" style="font-size:clamp(14px,2vw,18px)">Devenir exposant</a>
      <!-- Agenda dropdown -->
      <div style="position:relative">
        <button id="agenda-btn" class="btn btn-outline-w" style="font-size:clamp(13px,2vw,16px);padding:14px 22px">
          📅 Ajouter à l'agenda ▾
        </button>
        <div id="agenda-drop" style="display:none;position:absolute;top:calc(100%+8px);left:50%;translate:-50% 0;background:#fff;border-radius:var(--r-lg);padding:8px;box-shadow:0 8px 32px rgba(0,0,0,.25);min-width:220px;z-index:50;margin-top:8px">
          <a href={gcalUrl} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;text-decoration:none;color:var(--truffe);font-family:var(--f-body);font-size:13px;font-weight:500" onmouseover="this.style.background='var(--creme)'" onmouseout="this.style.background=''">
            📅 Google Calendar
          </a>
          <a href="/woofday-2026.ics" download style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;text-decoration:none;color:var(--truffe);font-family:var(--f-body);font-size:13px;font-weight:500" onmouseover="this.style.background='var(--creme)'" onmouseout="this.style.background=''">
            📱 Apple / Outlook (.ics)
          </a>
        </div>
      </div>
    </div>

    <!-- WhatsApp + compteur -->
    <div data-reveal data-delay="4" style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap">
      <a href={`https://wa.me/?text=${waText}`} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:var(--r-pill);padding:10px 18px;font-family:var(--f-body);font-size:13px;font-weight:600;color:#fff;text-decoration:none">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Partager sur WhatsApp
      </a>
      <!-- Compteur intéressés -->
      <div id="interest-block" style="
        display:inline-flex; align-items:center; gap:14px;
        background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25);
        border-radius:var(--r-md); padding:10px 20px;
        transition: transform .25s;
      ">
        <div style="display:flex">
          {['🐕','🐩','🦮'].map(d => (
            <span style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.2);display:inline-flex;align-items:center;justify-content:center;font-size:14px;margin-right:-5px;border:2px solid rgba(255,255,255,.3)">{d}</span>
          ))}
        </div>
        <div>
          <span id="interest-count" style="font-family:var(--f-head);font-size:24px;font-weight:700;color:var(--creme)">{count}</span>
          <span style="font-family:var(--f-body);font-size:12px;opacity:.8"> personnes intéressées</span>
        </div>
      </div>
    </div>

    <p data-reveal data-delay="4" style="font-family:var(--f-hand);font-size:18px;opacity:.7;margin-top:16px;transform:rotate(-1.5deg)">
      ...et le chiffre monte chaque jour ! 🐾
    </p>
  </div>

  <!-- Dog cutout hero — Golden assis vert sur fond orange -->
  <div class="dog-deco" style="right:clamp(0px,2vw,40px)">
    <img src="/images/dog-golden-assis2-vert.png" alt="" aria-hidden="true"
      style="width:clamp(260px,36vw,480px);display:block;
             filter:drop-shadow(0 -8px 32px rgba(0,0,0,.3));" />
  </div>

  <!-- Slant bottom -->
  <div style="position:absolute;bottom:-1px;left:0;right:0;height:60px;background:var(--bg);clip-path:polygon(0 100%,100% 0,100% 100%)"></div>
</section>

<!-- ══════════════════════════════════ BANDEROLE DÉFILANTE ══ -->
<div style="background:var(--truffe);padding:18px 0;overflow:hidden;position:relative;z-index:2;border-top:4px solid rgba(255,255,255,.12);border-bottom:4px solid rgba(255,255,255,.12)" aria-hidden="true">
  <div class="marquee-strip">
    <div class="marquee-track">
      {[
        {img:'/logos/LOGOCOULEURV1.svg', sep:'🐾'},
        {img:'/logos/LOGOCOULEURV2.svg', sep:'✦'},
        {img:'/logos/LOGOCOULEURV3.svg', sep:'🐾'},
        {img:'/logos/LOGOCOULEURV4.svg', sep:'✦'},
        {img:'/logos/LOGOCOULEURV5.svg', sep:'🐾'},
        {img:'/logos/LOGOCOULEURV1.svg', sep:'✦'},
        {img:'/logos/LOGOCOULEURV2.svg', sep:'🐾'},
        {img:'/logos/LOGOCOULEURV3.svg', sep:'✦'},
        {img:'/logos/LOGOCOULEURV4.svg', sep:'🐾'},
        {img:'/logos/LOGOCOULEURV5.svg', sep:'✦'},
      ].map((item) => (
        <div style="display:inline-flex;align-items:center;gap:28px;padding:0 32px;flex-shrink:0">
          <img src={item.img} alt="Woof Day" style="height:60px;width:auto;display:block;flex-shrink:0" />
          <span style="font-size:24px;color:rgba(255,255,255,.2);flex-shrink:0">{item.sep}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════ POURQUOI VENIR ══ -->
<section id="pourquoi" class="sec" style="background:var(--bg)">
  <div class="inner">
    <div style="text-align:center;margin-bottom:clamp(32px,5vw,56px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-terre">L'événement</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,58px);color:var(--truffe)">Pourquoi venir<br/>au Woof Day ?</h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-bottom:40px">
      {[
        { num: '01', titre: 'Une vraie sortie du dimanche', desc: 'Pas un événement figé. Une journée locale, joyeuse et vivante près d\'Angoulême.', bg: 'var(--terre)', color: '#fff' },
        { num: '02', titre: 'De quoi faire toute la journée', desc: 'Plus de 50 stands, animations et concours pour découvrir, rire, flâner et profiter.', bg: 'var(--vert)', color: '#fff' },
        { num: '03', titre: 'C\'est accessible', desc: 'Entrée gratuite, ambiance familiale, avec ou sans chien. Parking gratuit sur place.', bg: 'var(--creme)', color: 'var(--truffe)' },
