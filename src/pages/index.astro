---
import Layout from '../layouts/Layout.astro';
import DoodleMark from '../components/DoodleMark.astro';
import LogoTicker from '../components/LogoTicker.astro';
import { ContactForm } from '../components/ContactForm';
import { getInterestCount, getZonesStands, getFiches } from '../lib/data';

let count = 413;
let activities: Awaited<ReturnType<typeof getZonesStands>> = [];
let fiches: Awaited<ReturnType<typeof getFiches>> = [];

try {
  [count, activities, fiches] = await Promise.all([
    getInterestCount(),
    getZonesStands({ onlyVisible: true }),
    getFiches({ onlyVisible: true, exposants: true }),
  ]);
  activities = activities.sort((a, b) => a.displayOrder - b.displayOrder);
} catch (e) {
  console.error('[index] DB unavailable, using fallbacks:', e);
}

const FALLBACK_EXPOSANTS = [
  { nom: 'Caninéo Santé', descriptionCourte: 'Alimentation naturelle et locale pour chiens.', visuelUrl: 'https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=120&h=120&q=80&fit=crop', instagram: '@cadineo_sante', color: '#de6c49', emoji: '🦴', pole: 'Alimentation & Friandises' },
  { nom: 'Doggy Toys 16', descriptionCourte: 'Accessoires, laisses et jouets éco-responsables.', visuelUrl: 'https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=120&h=120&q=80&fit=crop', instagram: '@doggytoys16', color: '#26422b', emoji: '🧶', pole: 'Créateur Accessoires' },
  { nom: 'Aqua Dog Charente', descriptionCourte: 'Spécialistes des activités aquatiques canines.', visuelUrl: 'https://images.unsplash.com/photo-1518717758536-85ae29035b6d?w=120&h=120&q=80&fit=crop', instagram: '@aquadog_charente', color: '#91acda', emoji: '🌊', pole: 'Activités Sportives' },
];

const FALLBACK_ACTIVITIES = [
  { id: 'z1', nom: 'Éducation & Relation', emoji: '🎓', description: 'Éducateurs, comportementalistes, agility et obéissance positive.', displayOrder: 1 },
  { id: 'z2', nom: 'Santé & Bien-être', emoji: '💚', description: 'Vétérinaires, ostéopathes, physiothérapie, relaxation et spa canin.', displayOrder: 2 },
  { id: 'z3', nom: 'Nutrition & Alimentation', emoji: '🥣', description: 'Alimentation naturelle, croquettes artisanales, BARF et friandises.', displayOrder: 3 },
  { id: 'z4', nom: 'Activités & Fun', emoji: '🏃', description: 'Sport canin, zone aquatique, randonnée, jeux et compétitions.', displayOrder: 4 },
  { id: 'z5', nom: 'Artisanat & Accessoires', emoji: '🧶', description: 'Colliers artisanaux, laisses, vêtements, bijoux et créations uniques.', displayOrder: 5 },
  { id: 'z6', nom: 'Associations & Solidarité', emoji: '❤️', description: 'Refuges, associations, adoption, bénévolat et protection animale.', displayOrder: 6 },
];
const exposantsToShow = fiches.length > 0 ? fiches.slice(0, 6) : FALLBACK_EXPOSANTS;
const activitiesToShow = activities.length > 0 ? activities : FALLBACK_ACTIVITIES;

const gcalUrl = "https://calendar.google.com/calendar/render?action=TEMPLATE&text=Woof+Day+2026&dates=20260913T080000Z/20260913T160000Z&details=La+grande+f%C3%AAte+canine+de+Charente+%E2%80%94+Entr%C3%A9e+gratuite+%F0%9F%90%BE&location=Amb%C3%A9rac%2C+Charente+(16)&sf=true&output=xml";

const faqs = [
  { q: "Le Woof Day est-il payant ?",         a: "Non, l'entrée est totalement gratuite." },
  { q: "Puis-je venir avec mon chien ?",       a: "Oui, les chiens sont les bienvenus, tenus en laisse." },
  { q: "Où a lieu le Woof Day ?",              a: "À Ambérac, près d'Angoulême, en Charente (16)." },
  { q: "Quand a lieu le Woof Day ?",           a: "Le dimanche 13 septembre 2026, de 10h à 18h." },
  { q: "Est-ce réservé aux passionnés ?",      a: "Non. Le Woof Day est ouvert à tous — avec ou sans chien." },
  { q: "Y aura-t-il des activités ?",          a: "Oui : 50+ exposants, animations, concours, tombola, activités aquatiques." },
  { q: "Le Woof Day soutient-il une cause ?",  a: "Oui. 100% des bénéfices nets reversés au Refuge de l'Angoumois." },
  { q: "Y aura-t-il de quoi manger ?",         a: "Oui, une buvette est ouverte sur place toute la journée. Boissons et petite restauration disponibles." },
  { q: "Y a-t-il un parking ?",                a: "Oui, le parking est gratuit et accessible sur place, directement à Ambérac." },
  { q: "Où suivre les annonces ?",             a: "Sur Instagram @woofday_charente et sur ce site." },
];

const waText = encodeURIComponent("Woof Day 2026 — Dimanche 13 sept à Ambérac ! Entrée gratuite 🐾 woofday.fr");
---

<Layout>
<div id="pbar" style="width:0%"></div>

<!-- ═══════════════════════════════════════════════════ NAV ══ -->
<nav id="nav" style="
  position: fixed; top: 16px; left: 50%; translate: -50% 0;
  z-index: 100; width: min(calc(100% - 32px), 1100px);
  background: rgba(243,241,199,.92); backdrop-filter: blur(12px);
  border: 1.5px solid var(--creme-dark); border-radius: var(--r-pill);
  padding: 10px 20px; display: flex; align-items: center; justify-content: space-between;
  transition: box-shadow .3s;
">
  <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none">
    <img src="/logos/tete-chien.svg" alt="" style="height:32px;width:32px;object-fit:contain" />
    <span style="font-family:var(--f-head);font-weight:700;font-size:18px;color:var(--truffe)">Woof Day</span>
  </a>
  <div class="nav-links" style="display:flex;align-items:center;gap:20px">
    {[['#pourquoi','Le Woof Day'],['#zones','Programme'],['#exposants','Le Village'],['#infos','Infos pratiques'],['/blog','Blog']].map(([h,l]) => (
      <a href={h} style="font-family:var(--f-body);font-size:14px;font-weight:600;color:var(--truffe);text-decoration:none;opacity:.8;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.8'">{l}</a>
    ))}
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <div class="nav-pro-links" style="display:flex;align-items:center;gap:6px">
      <a href="/exposants" style="font-family:var(--f-body);font-size:13px;font-weight:700;color:var(--terre);text-decoration:none;background:rgba(222,108,73,.1);border:1.5px solid rgba(222,108,73,.35);border-radius:var(--r-pill);padding:7px 14px;transition:background .2s" onmouseover="this.style.background='rgba(222,108,73,.2)'" onmouseout="this.style.background='rgba(222,108,73,.1)'">Devenir exposant 🏪</a>
      <a href="/sponsor" style="font-family:var(--f-body);font-size:13px;font-weight:700;color:var(--vert);text-decoration:none;background:rgba(38,66,43,.1);border:1.5px solid rgba(38,66,43,.3);border-radius:var(--r-pill);padding:7px 14px;transition:background .2s" onmouseover="this.style.background='rgba(38,66,43,.2)'" onmouseout="this.style.background='rgba(38,66,43,.1)'">Devenir sponsor 🤝</a>
    </div>
    <a href="#contact" id="btn-viens" class="btn btn-terre" style="font-size:14px;padding:10px 22px">Je suis intéressé 🐾</a>
    <button id="menu-toggle" class="nav-burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════ MENU MOBILE ══ -->
<div id="mobile-nav" role="dialog" aria-label="Navigation" style="
  position:fixed;top:72px;left:16px;right:16px;z-index:98;
  background:rgba(243,241,199,.97);backdrop-filter:blur(14px);
  border:1.5px solid var(--creme-dark);border-radius:var(--r-lg);
  padding:16px;box-shadow:0 8px 32px rgba(105,50,45,.18);
  flex-direction:column;gap:2px;
">
  <a href="#pourquoi" class="mobile-nav-link">🐾 Le Woof Day</a>
  <a href="#zones" class="mobile-nav-link">📅 Programme</a>
  <a href="#exposants-teaser" class="mobile-nav-link">🏪 Le Village</a>
  <a href="#infos" class="mobile-nav-link">📍 Infos pratiques</a>
  <a href="#faq" class="mobile-nav-link">💬 FAQ</a>
  <a href="/blog" class="mobile-nav-link">✍️ Blog & Actus</a>
  <div class="mobile-nav-sep"></div>
  <a href="/exposants" class="mobile-nav-link" style="font-size:14px;opacity:.8">🏪 Devenir exposant</a>
  <a href="/sponsor" class="mobile-nav-link" style="font-size:14px;opacity:.8">🤝 Devenir sponsor</a>
  <div class="mobile-nav-sep"></div>
  <a href="#contact" id="btn-viens-mobile" class="btn btn-terre" style="text-align:center;margin-top:4px">Je suis intéressé 🐾</a>
</div>

<!-- ═══════════════════════════════════════════════════ HERO ══ -->
<section style="
  min-height: 100svh; background: var(--terre); color: #fff;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 120px clamp(20px,5vw,40px) 80px;
  position: relative; overflow: hidden;
">
  <!-- Picto chien décoratif en fond -->
  <img src="/logos/tete-chien.svg" alt="" aria-hidden="true" style="
    position: absolute; right: -8%; bottom: -10%;
    width: clamp(280px, 45vw, 560px); opacity: .1;
    filter: brightness(0) invert(1); transform: rotate(-12deg);
    pointer-events: none; user-select: none;
  "/>

  <!-- Grandes pattes style PostInsta — bien visibles sur fond terre -->
  <div class="paw-float" style="--paw-dur:9s;--paw-delay:0s;top:-5%;left:-4%;font-size:clamp(180px,28vw,360px);color:rgba(255,255,255,.18);transform:rotate(-15deg);line-height:1">🐾</div>
  <div class="paw-float" style="--paw-dur:11s;--paw-delay:2s;bottom:10%;right:-6%;font-size:clamp(140px,22vw,300px);color:rgba(255,255,255,.14);transform:rotate(22deg);line-height:1">🐾</div>
  <div class="paw-float" style="--paw-dur:13s;--paw-delay:1s;top:50%;left:2%;font-size:clamp(80px,12vw,160px);color:rgba(255,255,255,.10);transform:rotate(-8deg);line-height:1">🐾</div>

  <!-- Logo chien en fond, grand, visible -->
  <img src="/logos/logo-chien-blanc.svg" alt="" aria-hidden="true" style="
    position:absolute;left:-6%;bottom:-8%;
    width:clamp(240px,40vw,500px);opacity:.08;
    pointer-events:none;user-select:none;transform:rotate(10deg);
  "/>

  <!-- Sticker badge tournant -->
  <div style="position:absolute;top:clamp(76px,11vw,130px);right:clamp(16px,5%,80px);z-index:4">
    <img src="/images/sticker-woofd.svg" alt="Woof Day" class="stamp-spin float-sticker"
      style="width:clamp(64px,9vw,110px);opacity:.82;filter:brightness(0) invert(1)" />
  </div>

  <!-- Flèche annotation "c'est gratuit !" -->
  <div class="arrow-deco" style="bottom:clamp(90px,14vw,170px);left:clamp(20px,7%,110px)">
    <div class="arrow-note" style="color:rgba(255,255,255,.65);transform:rotate(-8deg)">
      <DoodleMark variant="arrow" color="currentColor" style="position:relative;width:52px;height:auto;margin-bottom:4px" />
      c'est gratuit !
    </div>
  </div>

  <!-- Flèche annotation "13 sept" côté droit -->
  <div class="arrow-deco" style="bottom:clamp(60px,10vw,120px);right:clamp(20px,7%,120px)">
    <div class="arrow-note" style="color:rgba(255,255,255,.5);transform:rotate(6deg);text-align:right">
      marque le 13 sept !
      <DoodleMark variant="arrow" color="currentColor" style="position:relative;width:48px;height:auto;margin-top:4px;transform:scaleX(-1) rotate(10deg)" />
    </div>
  </div>

  <div style="position:relative;z-index:2;max-width:800px">
    <!-- Logo principal -->
    <div data-reveal style="margin-bottom:20px">
      <img src="/logos/logo-couleur.svg" alt="Woof Day" style="height:clamp(80px,16vw,160px);filter:brightness(0) invert(1);drop-shadow:0 4px 24px rgba(0,0,0,.2)" />
    </div>

    <h1 data-reveal data-delay="1" style="
      font-family:var(--f-head); font-size:clamp(22px,4vw,34px); font-weight:500;
      opacity:.9; margin-bottom:24px; line-height:1.25;
    ">La grande fête canine de Charente</h1>

    <!-- Proof pills -->
    <div data-reveal data-delay="1" style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:28px">
      {['✓ Entrée gratuite','🐕 Avec ou sans chien','⛺ 50+ stands','👥 1200+ visiteurs visés','❤️ Solidaire'].map(t => (
        <span style="background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:var(--r-pill);padding:6px 14px;font-family:var(--f-body);font-size:12px;font-weight:600">{t}</span>
      ))}
    </div>

    <!-- Date band -->
    <div data-reveal data-delay="2" style="
      display:inline-flex; align-items:center; gap:14px; flex-wrap:wrap; justify-content:center;
      background:rgba(0,0,0,.18); border-radius:var(--r-md); padding:12px 20px; margin-bottom:36px;
      font-family:var(--f-body); font-size:14px; font-weight:600; opacity:.95;
    ">
      <span id="rn-date">📅 Dimanche 13 septembre 2026</span>
      <span class="date-sep" style="opacity:.4">|</span>
      <span>🕙 10h – 18h</span>
      <span class="date-sep" style="opacity:.4">|</span>
      <span>📍 Ambérac, Charente (16)</span>
    </div>

    <!-- Countdown -->
    <div id="countdown" data-reveal data-delay="3" style="display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:36px"></div>

    <!-- CTA buttons -->
    <div data-reveal data-delay="3" style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:24px">
      <button id="btn-participe" class="btn btn-truffe" style="font-size:clamp(15px,2.5vw,20px);padding:16px 36px">
        Je suis intéressé 🐾
      </button>
      <a href="/exposants" class="btn btn-outline-w" style="font-size:clamp(14px,2vw,18px)">Devenir exposant</a>
      <a href="/sponsor" class="btn btn-outline-w" style="font-size:clamp(14px,2vw,18px)">Devenir sponsor</a>
      <!-- Agenda dropdown -->
      <div style="position:relative">
        <button id="agenda-btn" class="btn btn-outline-w" style="font-size:clamp(13px,2vw,16px);padding:14px 22px">
          📅 Ajouter à l'agenda ▾
        </button>
        <div id="agenda-drop" style="display:none;position:absolute;top:calc(100%+8px);left:50%;translate:-50% 0;background:#fff;border-radius:var(--r-lg);padding:8px;box-shadow:0 8px 32px rgba(0,0,0,.25);min-width:220px;z-index:50;margin-top:8px">
          <a href={gcalUrl} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;text-decoration:none;color:var(--truffe);font-family:var(--f-body);font-size:13px;font-weight:500" onmouseover="this.style.background='var(--creme)'" onmouseout="this.style.background=''">
            📅 Google Calendar
          </a>
          <a href="/woofday-2026.ics" download style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;text-decoration:none;color:var(--truffe);font-family:var(--f-body);font-size:13px;font-weight:500" onmouseover="this.style.background='var(--creme)'" onmouseout="this.style.background=''">
            📱 Apple / Outlook (.ics)
          </a>
        </div>
      </div>
    </div>

    <!-- WhatsApp + compteur -->
    <div data-reveal data-delay="4" style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap">
      <a href={`https://wa.me/?text=${waText}`} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:var(--r-pill);padding:10px 18px;font-family:var(--f-body);font-size:13px;font-weight:600;color:#fff;text-decoration:none">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Partager sur WhatsApp
      </a>
      <!-- Compteur intéressés -->
      <div id="interest-block" style="
        display:inline-flex; align-items:center; gap:14px;
        background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25);
        border-radius:var(--r-md); padding:10px 20px;
        transition: transform .25s;
      ">
        <div style="display:flex">
          {['🐕','🐩','🦮'].map(d => (
            <span style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.2);display:inline-flex;align-items:center;justify-content:center;font-size:14px;margin-right:-5px;border:2px solid rgba(255,255,255,.3)">{d}</span>
          ))}
        </div>
        <div>
          <span id="interest-count" style="font-family:var(--f-head);font-size:24px;font-weight:700;color:var(--creme)">{count}</span>
          <span style="font-family:var(--f-body);font-size:12px;opacity:.8"> personnes intéressées</span>
        </div>
      </div>
    </div>

    <p data-reveal data-delay="4" style="font-family:var(--f-hand);font-size:18px;opacity:.7;margin-top:16px;transform:rotate(-1.5deg)">
      ...et le chiffre monte chaque jour ! 🐾
    </p>
  </div>

  <!-- Dog cutout hero — Golden assis vert sur fond orange -->
  <div class="dog-deco" style="position:absolute;bottom:0;right:clamp(10px,2vw,30px);width:fit-content;pointer-events:none;line-height:0;z-index:1">
    <img src="/images/dog-golden-assis2-vert.png" alt="" aria-hidden="true"
      style="width:clamp(230px,32vw,440px);display:block;
             filter:drop-shadow(0 -8px 32px rgba(0,0,0,.3));" />
  </div>

  <!-- Slant bottom -->
  <div style="position:absolute;bottom:-1px;left:0;right:0;height:60px;background:var(--bg);clip-path:polygon(0 100%,100% 0,100% 100%)"></div>
</section>

<!-- ══════════════════════════════════ BANDEROLE DÉFILANTE ══ -->
<LogoTicker />

<!-- ══════════════════════════════════════════ POURQUOI VENIR ══ -->
<section id="pourquoi" class="sec" style="background:var(--bg);position:relative;overflow:hidden">
  <div class="paw-mark" style="right:-5%;top:-10%;color:var(--terre);transform:rotate(18deg)">🐾</div>
  <div class="paw-mark" style="left:-6%;bottom:-15%;color:var(--truffe);transform:rotate(-12deg);opacity:.09">🐾</div>
  <div class="inner" style="position:relative;z-index:2">
    <div style="text-align:center;margin-bottom:clamp(32px,5vw,56px)">
      <div data-reveal style="margin-bottom:16px"><span class="chip chip-terre">Le Woof Day</span></div>
      <h2 data-reveal data-delay="1" style="font-size:clamp(36px,5vw,58px);color:var(--truffe)">Plus qu'une fête,<br/>un état d'esprit</h2>
    </div>

    <!-- 3 Pillars -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;margin-bottom:64px">
      {[
        { t: 'Bienveillance', d: 'Une ambiance chaleureuse, respectueuse et positive pour tous les chiens et leurs humains.', e: '🧡', bg: 'var(--terre)', color: '#fff' },
        { t: 'Prévention', d: 'Des rencontres avec des professionnels pour mieux comprendre et soigner nos compagnons.', e: '🩺', bg: 'var(--truffe)', color: '#fff' },
        { t: 'Respect du vivant', d: 'Célébrer le chien dans sa juste nature, avec conscience et respect de ses besoins.', e: '🌿', bg: 'var(--vert)', color: '#fff' },
      ].map((v, i) => (
        <div data-reveal data-delay={String(i + 1)} style={`background:${v.bg};color:${v.color};padding:36px 32px;border-radius:var(--r-xl);position:relative;overflow:hidden`}>
          <div style={`font-family:var(--f-head);font-size:88px;font-weight:700;opacity:.1;position:absolute;top:-10px;right:12px;line-height:1;pointer-events:none`}>{String(i+1).padStart(2,'0')}</div>
          <div style="font-size:40px;margin-bottom:20px;position:relative;z-index:1">{v.e}</div>
          <h3 style="font-family:var(--f-head);font-size:24px;font-weight:700;margin-bottom:12px;position:relative;z-index:1">{v.t}</h3>
          <p style={`font-family:var(--f-body);font-size:15px;line-height:1.7;opacity:.85;position:relative;z-index:1`}>{v.d}</p>
        </div>
      ))}
    </div>

