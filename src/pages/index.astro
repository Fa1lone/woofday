<script define:vars={{ exposantsFictifs }}>
  // Progress bar
  window.addEventListener('scroll', () => {
    const el = document.getElementById('pbar');
    if (!el) return;
    const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100;
    el.style.width = pct + '%';
  });

  // Countdown
  function tick() {
    const diff = new Date('2026-09-13T10:00:00').getTime() - Date.now();
    if (diff <= 0) return;
    const parts = [
      { v: Math.floor(diff / 86400000),           l: 'Jours'  },
      { v: Math.floor(diff % 86400000 / 3600000), l: 'Heures' },
      { v: Math.floor(diff % 3600000  / 60000),   l: 'Min'    },
      { v: Math.floor(diff % 60000    / 1000),     l: 'Sec'    },
    ];
    const el = document.getElementById('countdown');
    if (!el) return;
    el.innerHTML = parts.map(({ v, l }) => `
      <div style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:16px;padding:12px 10px 10px;min-width:68px;text-align:center">
        <div style="font-family:'Fredoka',sans-serif;font-size:clamp(26px,5vw,40px);font-weight:700;line-height:1;color:var(--creme)">${String(v).padStart(2,'0')}</div>
        <div style="font-family:'Poppins',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;opacity:.6;margin-top:4px">${l}</div>
      </div>
    `).join('');
  }
  tick(); setInterval(tick, 1000);

  // Animate count
  function animCount(el, from, to) {
    const t0 = performance.now();
    const run = (now) => {
      const p = Math.min((now - t0) / 900, 1);
      el.textContent = Math.round(from + (to - from) * (1 - Math.pow(1 - p, 3)));
      if (p < 1) requestAnimationFrame(run);
    };
    requestAnimationFrame(run);
  }

  // "Je participe" button
  const btn = document.getElementById('btn-participe');
  const countEl = document.getElementById('interest-count');
  let voted = localStorage.getItem('wd_v') === '1';
  if (voted) { btn.textContent = '✅ Je participe !'; btn.style.background = '#26422b'; }

  btn?.addEventListener('click', async () => {
    if (voted) { document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' }); return; }
    const { default: confetti } = await import('canvas-confetti');
    const colors = ['#69322d','#de6c49','#26422b','#91acda','#f3f1c7'];
    confetti({ particleCount: 90, spread: 75, origin: { y: 0.45 }, colors });
    setTimeout(() => confetti({ particleCount: 45, angle: 60,  spread: 60, origin: { x: 0, y: 0.5 }, colors }), 180);
    setTimeout(() => confetti({ particleCount: 45, angle: 120, spread: 60, origin: { x: 1, y: 0.5 }, colors }), 300);
    try {
      const res = await fetch('/api/interest', { method: 'POST' });
      const { count } = await res.json();
      animCount(countEl, parseInt(countEl.textContent ?? '0'), count);
      localStorage.setItem('wd_v', '1');
      voted = true;
      btn.textContent = '✅ Je participe !';
      btn.style.background = '#26422b';
      const block = document.getElementById('interest-block');
      block.style.transform = 'scale(1.06)';
      setTimeout(() => block.style.transform = '', 320);
      window.showToast?.('🐾 Tu es comptabilisé·e !');
    } catch {}
  });

  // "Je viens" nav button — also increments counter
  document.getElementById('btn-viens')?.addEventListener('click', async () => {
    if (voted) return;
    try {
      const res = await fetch('/api/interest', { method: 'POST' });
      const { count } = await res.json();
      if (countEl) animCount(countEl, parseInt(countEl.textContent ?? '0', 10), count);
      localStorage.setItem('wd_v', '1');
      voted = true;
      if (btn) { btn.textContent = '✅ Je participe !'; btn.style.background = '#26422b'; }
    } catch {}
  });

  // Agenda dropdown
  const agendaBtn = document.getElementById('agenda-btn');
  const agendaDrop = document.getElementById('agenda-drop');
  agendaBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    agendaDrop.style.display = agendaDrop.style.display === 'block' ? 'none' : 'block';
  });
  document.addEventListener('click', () => { if (agendaDrop) agendaDrop.style.display = 'none'; });

  // FAQ
  document.querySelectorAll('.faq-btn').forEach(b => {
    b.addEventListener('click', () => {
      const item = b.closest('.faq-item');
      const body = item.querySelector('.faq-body');
      const chev = item.querySelector('.faq-chevron');
      const open = body.style.display !== 'none';
      body.style.display = open ? 'none' : 'block';
      chev.style.transform = open ? '' : 'rotate(180deg)';
      item.style.background = open ? 'rgba(255,255,255,.08)' : 'rgba(255,255,255,.14)';
    });
  });

  // Contact form
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type=submit]');
    submitBtn.textContent = 'Envoi…'; submitBtn.disabled = true;
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form))) });
      if (res.ok) {
        form.style.display = 'none';
        document.getElementById('contact-success').style.display = 'block';
        window.showToast?.('✅ Message envoyé !');
      } else throw new Error();
    } catch { submitBtn.textContent = '❌ Erreur — Réessayez'; submitBtn.disabled = false; }
  });

  // Exposant modal
  window.openExpModal = (i) => {
    const e = exposantsFictifs[i];
    const avatar = document.getElementById('exp-avatar');
    avatar.style.background = e.color;
    avatar.innerHTML = `<img src="${e.photo}" alt="${e.nom}" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='${e.emoji}';this.parentElement.style.display='flex';this.parentElement.style.alignItems='center';this.parentElement.style.justifyContent='center';this.parentElement.style.fontSize='36px'" />`;
    document.getElementById('exp-badge').textContent = e.activite;
    document.getElementById('exp-nom').textContent = e.nom;
    document.getElementById('exp-desc').textContent = e.long;
    const links = document.getElementById('exp-links');
    links.innerHTML = '';
    if (e.instagram) {
      const a = document.createElement('a');
      a.href = `https://instagram.com/${e.instagram.replace('@','')}`;
      a.target = '_blank'; a.rel = 'noopener';
      a.className = 'btn btn-outline-t';
      a.style.fontSize = '13px'; a.style.padding = '8px 18px';
      a.textContent = '📸 ' + e.instagram;
      links.appendChild(a);
    }
    const modal = document.getElementById('exp-modal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };

  window.closeExpModal = () => {
    document.getElementById('exp-modal').style.display = 'none';
    document.body.style.overflow = '';
  };

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') window.closeExpModal?.(); });
</script>

<!-- Rough Notation — annotations hand-drawn sur éléments clés -->
<script type="module">
  import { annotate } from 'https://unpkg.com/rough-notation@0.6.1/lib/rough-notation.esm.js';

  const run = () => {
    const dateEl  = document.getElementById('rn-date');
    const centEl  = document.getElementById('rn-cent');
    const causeEl = document.getElementById('rn-cause');

    if (dateEl) annotate(dateEl, {
      type: 'underline', color: '#f3f1c7', strokeWidth: 2.5, padding: 3, animate: true, animationDuration: 800
    }).show();

    if (centEl) annotate(centEl, {
      type: 'circle', color: '#de6c49', strokeWidth: 2.8, padding: 6, animate: true, animationDuration: 900
    }).show();

    if (causeEl) annotate(causeEl, {
      type: 'underline', color: '#de6c49', strokeWidth: 3, padding: 2, animate: true, animationDuration: 700
    }).show();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
</script>
