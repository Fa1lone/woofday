<div id="exp-modal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:20px" onclick="if(event.target===this)closeExpModal()">
  <div style="background:#fff;border-radius:var(--r-xl);padding:clamp(24px,5vw,40px);max-width:480px;width:100%;position:relative;box-shadow:0 24px 64px rgba(0,0,0,.25);max-height:90vh;overflow-y:auto">
    <button onclick="closeExpModal()" style="position:absolute;top:16px;right:16px;background:var(--creme);border:none;border-radius:50%;width:36px;height:36px;cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;color:var(--truffe);line-height:1">×</button>
    <div id="exp-avatar" style="width:80px;height:80px;border-radius:var(--r-lg);overflow:hidden;margin-bottom:16px;flex-shrink:0"></div>
    <div id="exp-badge" class="chip chip-terre" style="margin-bottom:12px"></div>
    <h3 id="exp-nom" style="font-family:var(--f-head);font-size:28px;font-weight:700;color:var(--truffe);margin-bottom:10px"></h3>
    <p id="exp-desc" style="font-family:var(--f-body);font-size:15px;line-height:1.7;color:var(--truffe);opacity:.8;margin-bottom:20px"></p>
    <div id="exp-links" style="display:flex;gap:10px;flex-wrap:wrap"></div>
  </div>
</div>
</Layout>

<script define:vars={{ exposantsToShow }}>
  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle');
  const mobileNav  = document.getElementById('mobile-nav');
  menuToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = mobileNav.style.display === 'flex';
    mobileNav.style.display = open ? 'none' : 'flex';
    menuToggle.setAttribute('aria-expanded', String(!open));
    const lines = menuToggle.querySelectorAll('span');
    if (open) {
      lines[0].style.transform = ''; lines[1].style.opacity = '1'; lines[2].style.transform = '';
    } else {
      lines[0].style.transform = 'translateY(6px) rotate(45deg)';
      lines[1].style.opacity = '0';
      lines[2].style.transform = 'translateY(-6px) rotate(-45deg)';
    }
  });
  mobileNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    mobileNav.style.display = 'none';
    menuToggle?.setAttribute('aria-expanded', 'false');
    const lines = menuToggle?.querySelectorAll('span');
    if (lines) { lines[0].style.transform=''; lines[1].style.opacity='1'; lines[2].style.transform=''; }
  }));
  document.addEventListener('click', (e) => {
    if (!menuToggle?.contains(e.target) && !mobileNav?.contains(e.target)) {
      if (mobileNav) mobileNav.style.display = 'none';
      menuToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Progress bar
  window.addEventListener('scroll', () => {
    const el = document.getElementById('pbar');
    if (!el) return;
    const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100;
    el.style.width = pct + '%';
  });

  // Countdown
  function tick() {
    const diff = new Date('2026-09-13T10:00:00').getTime() - Date.now();
    if (diff <= 0) return;
    const parts = [
      { v: Math.floor(diff / 86400000),           l: 'Jours'  },
      { v: Math.floor(diff % 86400000 / 3600000), l: 'Heures' },
      { v: Math.floor(diff % 3600000  / 60000),   l: 'Min'    },
      { v: Math.floor(diff % 60000    / 1000),     l: 'Sec'    },
    ];
    const el = document.getElementById('countdown');
    if (!el) return;
    el.innerHTML = parts.map(({ v, l }) => `
      <div style="background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:16px;padding:12px 10px 10px;min-width:68px;text-align:center">
        <div style="font-family:'Fredoka',sans-serif;font-size:clamp(26px,5vw,40px);font-weight:700;line-height:1;color:var(--creme)">${String(v).padStart(2,'0')}</div>
        <div style="font-family:'Poppins',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;opacity:.6;margin-top:4px">${l}</div>
      </div>
    `).join('');
  }
  tick(); setInterval(tick, 1000);

  // Animate count
  function animCount(el, from, to) {
    const t0 = performance.now();
    const run = (now) => {
      const p = Math.min((now - t0) / 900, 1);
      el.textContent = Math.round(from + (to - from) * (1 - Math.pow(1 - p, 3)));
      if (p < 1) requestAnimationFrame(run);
    };
    requestAnimationFrame(run);
  }

  // Shared "Je participe" logic — hero + header (desktop + mobile)
  const btn = document.getElementById('btn-participe') as HTMLButtonElement | null;
  const btnViens = document.getElementById('btn-viens') as HTMLAnchorElement | null;
  const btnViensMobile = document.getElementById('btn-viens-mobile') as HTMLAnchorElement | null;
  const countEl = document.getElementById('interest-count');
  let voted = localStorage.getItem('wd_v') === '1';

  const markAllVoted = () => {
    if (btn) { btn.textContent = '✅ Je participe !'; btn.style.background = '#26422b'; }
    if (btnViens) { btnViens.textContent = '✅ Je participe !'; }
    if (btnViensMobile) { btnViensMobile.textContent = '✅ Je participe !'; }
  };

  if (voted) markAllVoted();

  const fireParticipe = async (e?: Event) => {
    e?.preventDefault();
    if (voted) { document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' }); return; }
    const { default: confetti } = await import('canvas-confetti');
    const colors = ['#69322d','#de6c49','#26422b','#91acda','#f3f1c7'];
    confetti({ particleCount: 90, spread: 75, origin: { y: 0.45 }, colors });
    setTimeout(() => confetti({ particleCount: 45, angle: 60,  spread: 60, origin: { x: 0, y: 0.5 }, colors }), 180);
    setTimeout(() => confetti({ particleCount: 45, angle: 120, spread: 60, origin: { x: 1, y: 0.5 }, colors }), 300);
    try {
      const res = await fetch('/api/interest', { method: 'POST' });
      const { count } = await res.json();
      if (countEl) animCount(countEl, parseInt(countEl.textContent ?? '0'), count);
      localStorage.setItem('wd_v', '1');
      voted = true;
      markAllVoted();
      const block = document.getElementById('interest-block');
      if (block) {
        block.style.transform = 'scale(1.06)';
        setTimeout(() => block.style.transform = '', 320);
      }
      window.showToast?.('🐾 Tu es comptabilisé·e !');
    } catch {}
  };

  btn?.addEventListener('click', fireParticipe);
  btnViens?.addEventListener('click', fireParticipe);
  btnViensMobile?.addEventListener('click', fireParticipe);

  // Agenda dropdown
  const agendaBtn = document.getElementById('agenda-btn');
  const agendaDrop = document.getElementById('agenda-drop');
  agendaBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (agendaDrop) agendaDrop.style.display = agendaDrop.style.display === 'block' ? 'none' : 'block';
  });
  document.addEventListener('click', () => { if (agendaDrop) agendaDrop.style.display = 'none'; });

  // FAQ
  document.querySelectorAll('.faq-btn').forEach(b => {
    b.addEventListener('click', () => {
      const item = b.closest('.faq-item');
      const body = item?.querySelector('.faq-body');
      const chev = item?.querySelector('.faq-chevron');
      const open = body?.style.display !== 'none';
      if (body) body.style.display = open ? 'none' : 'block';
      if (chev) chev.style.transform = open ? '' : 'rotate(180deg)';
      if (item) item.style.background = open ? 'rgba(255,255,255,.08)' : 'rgba(255,255,255,.14)';
    });
  });

  // Contact form
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type=submit]');
    submitBtn.textContent = 'Envoi…'; submitBtn.disabled = true;
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form))) });
      if (res.ok) {
        form.style.display = 'none';
        const successEl = document.getElementById('contact-success');
        if (successEl) successEl.style.display = 'block';
        window.showToast?.('✅ Message envoyé !');
      } else throw new Error();
    } catch { submitBtn.textContent = '❌ Erreur — Réessayez'; submitBtn.disabled = false; }
  });

  // Exposant modal
  window.openExpModal = (i) => {
    const e = exposantsToShow[i];
    const avatar = document.getElementById('exp-avatar');
    if (avatar) {
      avatar.style.background = e.color ?? 'var(--terre)';
      avatar.innerHTML = `<img src="${e.visuelUrl}" alt="${e.nom}" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentElement.innerHTML='${e.emoji ?? '🐾'}';this.parentElement.style.display='flex';this.parentElement.style.alignItems='center';this.parentElement.style.justifyContent='center';this.parentElement.style.fontSize='36px'" />`;
    }
    const badge = document.getElementById('exp-badge');
    if (badge) badge.textContent = e.pole ?? '';
    const nom = document.getElementById('exp-nom');
    if (nom) nom.textContent = e.nom;
    const desc = document.getElementById('exp-desc');
    if (desc) desc.textContent = e.descriptionCourte ?? '';
    const links = document.getElementById('exp-links');
    if (links) {
      links.innerHTML = '';
      if (e.instagram) {
        const a = document.createElement('a');
        a.href = `https://instagram.com/${e.instagram.replace('@','')}`;
        a.target = '_blank'; a.rel = 'noopener';
        a.className = 'btn btn-outline-t';
        a.style.fontSize = '13px'; a.style.padding = '8px 18px';
        a.textContent = '📸 ' + e.instagram;
        links.appendChild(a);
      }
      if (e.siteWeb) {
        const a = document.createElement('a');
        a.href = e.siteWeb;
        a.target = '_blank'; a.rel = 'noopener';
        a.className = 'btn btn-outline-t';
        a.style.fontSize = '13px'; a.style.padding = '8px 18px';
        a.textContent = '🌐 Site Web';
        links.appendChild(a);
      }
    }
    const modal = document.getElementById('exp-modal');
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeExpModal = () => {
    const modal = document.getElementById('exp-modal');
    if (modal) modal.style.display = 'none';
    document.body.style.overflow = '';
  };

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') window.closeExpModal?.(); });
</script>

<!-- Rough Notation — annotations hand-drawn sur éléments clés -->
<script type="module">
  import { annotate } from 'https://unpkg.com/rough-notation@0.6.1/lib/rough-notation.esm.js';

  const run = () => {
    const dateEl  = document.getElementById('rn-date');
    const centEl  = document.getElementById('rn-cent');
    const causeEl = document.getElementById('rn-cause');

    if (dateEl) annotate(dateEl, {
      type: 'underline', color: '#f3f1c7', strokeWidth: 2.5, padding: 3, animate: true, animationDuration: 800
    }).show();

    if (centEl) annotate(centEl, {
      type: 'circle', color: '#de6c49', strokeWidth: 2.8, padding: 6, animate: true, animationDuration: 900
    }).show();

    if (causeEl) annotate(causeEl, {
      type: 'underline', color: '#de6c49', strokeWidth: 3, padding: 2, animate: true, animationDuration: 700
    }).show();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
</script>
