{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/activity/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/activity/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/export/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/exposant/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/exposant/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/exposant/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/interest/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsor/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsor/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsor/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/activities/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/contacts/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/sponsors/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/exposants/?$",
			"dest": "_render"
		},
		{
			"src": "^/sponsor/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}